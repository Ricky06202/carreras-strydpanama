---
import Layout from '../../layouts/Layout.astro';
import { api } from '../../lib/api';
import { env } from 'cloudflare:workers';
import RaceTimer from '../../components/RaceTimer';

const raceId = Astro.params.id;
let race = null;
let error = null;
let envKeys = 'NO ENV';

if (env) {
  envKeys = Object.keys(env).join(', ');
} else {
  console.error('ENV IS UNDEFINED!');
}

try {
  console.log('Fetching race:', raceId);
  console.log('ENV keys:', envKeys);
  
  const raceData = await api.getRace(env, raceId || '');
  console.log('Race data:', JSON.stringify(raceData, null, 2).substring(0, 300));
  
  // getRace returns { data: { race object } }
  if (raceData?.data?.id) {
    race = raceData.data;
    console.log('Race found:', race.title);
  } else {
    console.log('No race data found');
  }
} catch (e) {
  error = e.message;
  console.error('Error fetching race:', e);
}

if (!race) {
  console.log('Race is null. RaceId:', raceId, 'Error:', error);
  // Don't redirect, just show debug info
  race = { id: raceId, title: 'DEBUG: Race not found', data: { title: 'Race not found', description: error || 'No race data' } };
}

function formatDate(dateStr: string) {
  if (!dateStr) return 'Por definir';
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-PA', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}

const raceData = race?.data || {};
---

<Layout title={`${raceData.title || race.title || 'Carrera'} - Stryd Panama`}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <a href="/" class="inline-flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-accent mb-6 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a Carreras
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <div class="bg-white dark:bg-slate-900 rounded-[32px] shadow-lg overflow-hidden relative">
          {raceData.imageUrl ? (
            <img src={raceData.imageUrl} alt={raceData.title} class="w-full h-auto min-h-[300px] max-h-[500px] object-contain bg-slate-950" />
          ) : (
            <div class="h-48 bg-gradient-to-br from-neutral-800 to-neutral-900 flex items-center justify-center relative">
              <svg class="w-24 h-24 text-white opacity-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          )}
          {raceData.status === 'active' && (
            <div class="absolute top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-full font-bold animate-pulse">
              EN VIVO
            </div>
          )}
          <div class="p-8">
            <h1 class="text-3xl font-bold mb-4 dark:text-white">{raceData.title || race.title}</h1>
            <p class="text-gray-600 dark:text-gray-400 mb-6">{raceData.description || ''}</p>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
              <div class="text-center p-4 bg-gray-50 dark:bg-slate-800 rounded-2xl">
                <div class="text-2xl font-bold text-accent">${raceData.price || 0}</div>
                <div class="text-sm text-gray-500">Precio</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-slate-800 rounded-2xl">
                <div class="text-2xl font-bold text-accent">
                  {raceData.maxParticipants ? raceData.maxParticipants : '∞'}
                </div>
                <div class="text-sm text-gray-500">Cupo Máximo</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-slate-800 rounded-2xl">
                <div class="text-2xl font-bold text-accent">{formatDate(raceData.date)}</div>
                <div class="text-sm text-gray-500">Fecha</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-slate-800 rounded-2xl">
                <div class="text-2xl font-bold text-accent">{raceData.status === 'accepting' ? 'Abierta' : raceData.status}</div>
                <div class="text-sm text-gray-500">Estado</div>
              </div>
            </div>

            {raceData.location && (
              <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400 mb-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {raceData.location}
              </div>
            )}

            {raceData.technicalInfo && (
              <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 mb-6">
                <h3 class="text-lg font-bold mb-3 dark:text-white">Información Técnica</h3>
                <p class="text-gray-600 dark:text-gray-400 whitespace-pre-wrap">{raceData.technicalInfo}</p>
              </div>
            )}

            {raceData.termsAndConditions && (
              <div class="bg-gray-50 dark:bg-slate-800 rounded-2xl p-6 mb-6">
                <h3 class="text-lg font-bold mb-3 dark:text-white">Términos y Condiciones</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm whitespace-pre-wrap">{raceData.termsAndConditions}</p>
              </div>
            )}

            {raceData.status === 'accepting' && (
              <a href={`/register?race=${raceId}`} class="block w-full text-center px-8 py-4 bg-accent text-white text-lg font-bold rounded-2xl hover:opacity-90 transition-colors">
                Inscribirse Ahora
              </a>
            )}
            
            {raceData.status === 'upcoming' && (
              <div class="block w-full text-center px-8 py-4 bg-gray-300 dark:bg-slate-700 text-gray-500 dark:text-gray-400 text-lg font-bold rounded-2xl cursor-not-allowed select-none">
                Inscripciones Próximamente
              </div>
            )}
          </div>
        </div>
      </div>

      <div class="space-y-8">
        {raceData.showTimer !== false && raceData.timerStart && (
          <div class="bg-white dark:bg-slate-900 rounded-[32px] shadow-lg p-6">
            <h2 class="text-xl font-bold mb-4">Información</h2>
            <div class="space-y-4">
              <RaceTimer 
                client:only="react"
                raceName={raceData.title || race.title}
                raceStatus={raceData.status}
                timerStart={raceData.timerStart}
                timerStop={raceData.timerStop}
              />
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
