---
import Layout from '../layouts/Layout.astro';
import HomePage from '../components/HomePage';
import { api } from '../lib/api';

let racesData = { data: [] };
const runtime = Astro.locals.runtime;

try {
  const response = await api.getPublicRaces(runtime?.env || {});
  racesData = response;
} catch (e) {
  console.error('Error fetching races:', e);
}
---

<Layout title="Inicio - Carreras by StrydPanama">
  <HomePage client:load initialRaces={racesData.data} />
</Layout>
