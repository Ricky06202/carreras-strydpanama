---
import AstroLayout from '../layouts/Layout.astro';
---
<AstroLayout title="Mis Inscripciones — Carreras STRYD Panama">
  <div id="app-root"></div>
</AstroLayout>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #0f0f0f; color: #fff; font-family: 'Inter', sans-serif; }

.page { max-width: 700px; margin: 0 auto; padding: 32px 16px; }
.header { background: #000; border-bottom: 2px solid #FF6B00; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; }
.logo { color: #FF6B00; font-size: 18px; font-weight: 900; letter-spacing: 2px; text-decoration: none; }

.search-card { background: #1a1a1a; border-radius: 20px; padding: 32px; border: 1px solid #2d2d2d; margin-bottom: 24px; }
.search-title { font-size: 22px; font-weight: 900; margin-bottom: 8px; }
.search-sub { color: #888; font-size: 14px; margin-bottom: 24px; }
.search-row { display: flex; gap: 12px; }
.input-field {
  flex: 1; background: #2d2d2d; border: 1px solid #3d3d3d; color: #fff;
  padding: 14px 16px; border-radius: 12px; font-size: 16px; outline: none;
  transition: border-color 0.2s;
}
.input-field:focus { border-color: #FF6B00; }
.btn-search {
  background: #FF6B00; color: #fff; border: none; padding: 14px 28px;
  border-radius: 12px; font-weight: 700; font-size: 15px; cursor: pointer;
  transition: background 0.2s;
}
.btn-search:hover { background: #E55A00; }
.btn-search:disabled { opacity: 0.5; cursor: not-allowed; }

.reg-card { background: #1a1a1a; border-radius: 20px; border: 1px solid #2d2d2d; overflow: hidden; margin-bottom: 16px; }
.reg-header { display: flex; align-items: center; gap: 16px; padding: 20px; border-bottom: 1px solid #2d2d2d; }
.race-img { width: 60px; height: 60px; border-radius: 12px; object-fit: cover; background: #2d2d2d; flex-shrink: 0; }
.race-name { font-size: 18px; font-weight: 700; }
.race-date { font-size: 13px; color: #888; margin-top: 2px; }
.status-badge {
  margin-left: auto; padding: 6px 14px; border-radius: 20px;
  font-size: 12px; font-weight: 700; letter-spacing: 0.5px; white-space: nowrap;
}
.status-confirmed { background: #0d2e0d; color: #4caf50; border: 1px solid #4caf50; }
.status-pending { background: #2e1a00; color: #FF8533; border: 1px solid #FF6B00; }
.status-rejected { background: #2e0000; color: #f44336; border: 1px solid #f44336; }

.reg-body { padding: 20px; display: flex; align-items: center; gap: 20px; }
.runner-pic { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 3px solid #FF6B00; flex-shrink: 0; }
.runner-pic-placeholder { width: 80px; height: 80px; border-radius: 50%; background: #2d2d2d; border: 3px solid #333; display: flex; align-items: center; justify-content: center; font-size: 30px; flex-shrink: 0; }
.reg-info { flex: 1; }
.reg-name { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.reg-detail { font-size: 13px; color: #888; }
.bib { display: inline-block; background: #FF6B00; color: #fff; padding: 3px 10px; border-radius: 8px; font-weight: 700; font-size: 13px; margin-bottom: 6px; }
.btn-update-photo { background: transparent; border: 1px solid #FF6B00; color: #FF6B00; padding: 8px 16px; border-radius: 10px; font-size: 13px; cursor: pointer; transition: all 0.2s; }
.btn-update-photo:hover { background: rgba(255,107,0,0.1); }

/* Crop Modal */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 16px; }
.modal { background: #111; border-radius: 24px; border: 1px solid #2d2d2d; width: 100%; max-width: 480px; overflow: hidden; }
.modal-header { padding: 20px 24px; border-bottom: 1px solid #2d2d2d; display: flex; align-items: center; justify-content: space-between; }
.modal-title { font-size: 18px; font-weight: 700; }
.modal-close { background: none; border: none; color: #888; font-size: 22px; cursor: pointer; line-height: 1; }
.modal-body { padding: 24px; }
.crop-instructions { color: #888; font-size: 13px; margin-bottom: 16px; text-align: center; }

/* Crop Area */
.crop-container { position: relative; width: 100%; aspect-ratio: 1; background: #000; border-radius: 16px; overflow: hidden; cursor: crosshair; touch-action: none; }
.crop-image { position: absolute; transform-origin: center; user-select: none; pointer-events: none; }
.crop-overlay { position: absolute; inset: 0; }
.crop-circle { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 70%; aspect-ratio: 1; border-radius: 50%; border: 3px solid #FF6B00; box-shadow: 0 0 0 9999px rgba(0,0,0,0.6); pointer-events: none; }
.crop-hint { position: absolute; bottom: 12px; left: 0; right: 0; text-align: center; color: rgba(255,255,255,0.5); font-size: 12px; pointer-events: none; }

.crop-controls { display: flex; align-items: center; gap: 12px; margin: 16px 0 0; }
.zoom-label { color: #888; font-size: 12px; white-space: nowrap; }
.zoom-slider { flex: 1; accent-color: #FF6B00; }

.upload-area { border: 2px dashed #3d3d3d; border-radius: 16px; padding: 40px; text-align: center; cursor: pointer; transition: border-color 0.2s; }
.upload-area:hover { border-color: #FF6B00; }
.upload-icon { font-size: 40px; margin-bottom: 12px; }
.upload-text { color: #888; font-size: 14px; }
.upload-text span { color: #FF6B00; font-weight: 600; }

.modal-footer { padding: 16px 24px; border-top: 1px solid #2d2d2d; display: flex; gap: 12px; }
.btn-cancel { flex: 1; background: #2d2d2d; color: #fff; border: none; padding: 12px; border-radius: 12px; font-weight: 600; cursor: pointer; }
.btn-confirm { flex: 2; background: #FF6B00; color: #fff; border: none; padding: 12px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: background 0.2s; }
.btn-confirm:hover { background: #E55A00; }
.btn-confirm:disabled { opacity: 0.5; cursor: not-allowed; }

.error-msg { color: #f44336; font-size: 14px; text-align: center; padding: 12px; }
.success-msg { color: #4caf50; font-size: 14px; text-align: center; padding: 12px; }
.loading { color: #888; text-align: center; padding: 40px; font-size: 14px; }
.empty { color: #555; text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 50px; margin-bottom: 16px; }
</style>

<script>
const ACCENT = '#FF6B00';
let registrations = [];
let cropModal = { open: false, participantId: null, cedula: null, currentPhotoUrl: null };
let cropState = { image: null, scale: 1, offsetX: 0, offsetY: 0, isDragging: false, startX: 0, startY: 0, lastTouchDist: 0 };

// ---- RENDER ----
function render() {
  const root = document.getElementById('app-root');
  root.innerHTML = `
    <header class="header">
      <a href="/" class="logo">STRYD PANAMA</a>
      <a href="/registro" style="color:#FF6B00;font-size:13px;text-decoration:none;">+ Nueva Inscripción</a>
    </header>
    <div class="page">
      ${renderSearch()}
      ${renderRegistrations()}
    </div>
    ${cropModal.open ? renderCropModal() : ''}
  `;
  attachEvents();
}

function renderSearch() {
  return `
    <div class="search-card">
      <div class="search-title">🔍 Mis Inscripciones</div>
      <div class="search-sub">Ingresa tu cédula o pasaporte para ver el estado de tus inscripciones y actualizar tu foto.</div>
      <div class="search-row">
        <input class="input-field" id="cedula-input" type="text" placeholder="Ej: 4-111-1111" />
        <button class="btn-search" id="search-btn" onclick="handleSearch()">Buscar</button>
      </div>
      ${window._searchError ? `<div class="error-msg">${window._searchError}</div>` : ''}
    </div>
  `;
}

function statusBadge(status) {
  if (status === 'confirmed' || status === 'paid') return `<span class="status-badge status-confirmed">✅ Confirmado</span>`;
  if (status === 'rejected') return `<span class="status-badge status-rejected">❌ Rechazado</span>`;
  return `<span class="status-badge status-pending">⏳ Pendiente</span>`;
}

function renderRegistrations() {
  if (window._searching) return `<div class="loading">⏳ Buscando inscripciones...</div>`;
  if (!registrations.length && window._searched) {
    return `<div class="empty"><div class="empty-icon">🏃</div><p style="color:#666;margin-bottom:8px;">No encontramos inscripciones con esa cédula.</p><p style="color:#444;font-size:13px;">¿Aún no te has inscrito? <a href="/registro" style="color:#FF6B00;">Regístrate aquí</a></p></div>`;
  }
  return registrations.map(reg => {
    const d = reg.race?.date ? new Date(reg.race.date).toLocaleDateString('es-PA', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
    const sonicBase = 'https://api.carreras.strydpanama.com';
    const imgSrc = reg.race?.imageUrl ? (reg.race.imageUrl.startsWith('http') ? reg.race.imageUrl : sonicBase + reg.race.imageUrl) : '';
    const photoSrc = reg.photoUrl ? (reg.photoUrl.startsWith('http') ? reg.photoUrl : sonicBase + reg.photoUrl) : '';
    return `
      <div class="reg-card">
        <div class="reg-header">
          ${imgSrc ? `<img src="${imgSrc}" class="race-img" />` : `<div class="race-img" style="display:flex;align-items:center;justify-content:center;font-size:24px;">🏁</div>`}
          <div>
            <div class="race-name">${reg.race?.title || 'Carrera'}</div>
            ${d ? `<div class="race-date">📅 ${d}</div>` : ''}
          </div>
          ${statusBadge(reg.paymentStatus)}
        </div>
        <div class="reg-body">
          ${photoSrc
            ? `<img src="${photoSrc}" class="runner-pic" />`
            : `<div class="runner-pic-placeholder">🏃</div>`
          }
          <div class="reg-info">
            <div class="bib">#${reg.bibNumber || '—'}</div>
            <div class="reg-name">${reg.firstName || ''} ${reg.lastName || ''}</div>
            ${reg.distance ? `<div class="reg-detail">📏 ${reg.distance}</div>` : ''}
            <div class="reg-detail" style="margin-top:8px;color:#${reg.paymentStatus==='confirmed'||reg.paymentStatus==='paid'?'4caf50':'FF8533'}">
              ${reg.paymentStatus === 'confirmed' || reg.paymentStatus === 'paid' ? '✅ Inscripción confirmada' : '⏳ En espera de confirmación de pago'}
            </div>
          </div>
          <button class="btn-update-photo" onclick="openCropModal('${reg.id}','${reg.cedula || ''}','${photoSrc}')">📸 Cambiar Foto</button>
        </div>
      </div>
    `;
  }).join('');
}

function renderCropModal() {
  return `
    <div class="modal-overlay" id="modal-overlay">
      <div class="modal">
        <div class="modal-header">
          <span class="modal-title">📸 Actualizar Foto de Perfil</span>
          <button class="modal-close" onclick="closeCropModal()">×</button>
        </div>
        <div class="modal-body">
          <div class="crop-instructions">Sube una foto y arrastra para centrar tu cara en el círculo. Usa la rueda del mouse o los dedos para ajustar el zoom.</div>
          ${cropState.image ? renderCropper() : renderUploadArea()}
          ${window._uploadError ? `<div class="error-msg">${window._uploadError}</div>` : ''}
          ${window._uploadSuccess ? `<div class="success-msg">✅ ¡Foto actualizada exitosamente!</div>` : ''}
        </div>
        ${cropState.image ? `
          <div class="modal-footer">
            <button class="btn-cancel" onclick="resetCrop()">↩ Elegir otra</button>
            <button class="btn-confirm" id="confirm-btn" onclick="confirmCrop()">
              ${window._uploading ? 'Guardando...' : '✓ Guardar Foto'}
            </button>
          </div>
        ` : ''}
      </div>
    </div>
  `;
}

function renderCropper() {
  return `
    <div class="crop-container" id="crop-container">
      <img id="crop-img" class="crop-image" src="${cropState.image}" style="
        transform: scale(${cropState.scale}) translate(${cropState.offsetX / cropState.scale}px, ${cropState.offsetY / cropState.scale}px);
        max-width: none; max-height: none; width: auto; height: 100%;
      " draggable="false" />
      <div class="crop-overlay">
        <div class="crop-circle"></div>
        <div class="crop-hint">Arrastra para centrar tu cara</div>
      </div>
    </div>
    <div class="crop-controls">
      <span class="zoom-label">🔍 Zoom</span>
      <input type="range" class="zoom-slider" id="zoom-slider" min="0.5" max="4" step="0.05" value="${cropState.scale}" oninput="handleZoomSlider(this.value)" />
    </div>
  `;
}

function renderUploadArea() {
  return `
    <div class="upload-area" onclick="document.getElementById('file-input').click()" id="upload-area">
      <div class="upload-icon">🤳</div>
      <div class="upload-text">Haz clic o arrastra tu foto aquí<br/><span>Elige una foto de tu cara</span></div>
      <input type="file" id="file-input" accept="image/*" style="display:none" onchange="handleFileSelect(this)" />
    </div>
  `;
}

// ---- EVENTS ----
function attachEvents() {
  const container = document.getElementById('crop-container');
  if (!container) return;

  let isDragging = false, lastX = 0, lastY = 0;

  container.addEventListener('mousedown', e => {
    isDragging = true; lastX = e.clientX; lastY = e.clientY; e.preventDefault();
  });
  window.addEventListener('mousemove', e => {
    if (!isDragging) return;
    cropState.offsetX += e.clientX - lastX;
    cropState.offsetY += e.clientY - lastY;
    lastX = e.clientX; lastY = e.clientY;
    updateCropImage();
  });
  window.addEventListener('mouseup', () => { isDragging = false; });

  container.addEventListener('wheel', e => {
    e.preventDefault();
    cropState.scale = Math.max(0.5, Math.min(4, cropState.scale - e.deltaY * 0.001));
    updateCropImage();
    const slider = document.getElementById('zoom-slider');
    if (slider) slider.value = cropState.scale;
  }, { passive: false });

  // Touch events
  let lastTouchDist = 0;
  container.addEventListener('touchstart', e => {
    if (e.touches.length === 1) { lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; }
    if (e.touches.length === 2) { lastTouchDist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY); }
    e.preventDefault();
  }, { passive: false });
  container.addEventListener('touchmove', e => {
    if (e.touches.length === 1) {
      cropState.offsetX += e.touches[0].clientX - lastX;
      cropState.offsetY += e.touches[0].clientY - lastY;
      lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
      updateCropImage();
    }
    if (e.touches.length === 2) {
      const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      cropState.scale = Math.max(0.5, Math.min(4, cropState.scale * (dist / lastTouchDist)));
      lastTouchDist = dist;
      updateCropImage();
    }
    e.preventDefault();
  }, { passive: false });
}

function updateCropImage() {
  const img = document.getElementById('crop-img');
  if (img) {
    img.style.transform = `scale(${cropState.scale}) translate(${cropState.offsetX / cropState.scale}px, ${cropState.offsetY / cropState.scale}px)`;
  }
}

// ---- ACTIONS ----
window.handleSearch = async function() {
  const cedula = document.getElementById('cedula-input')?.value?.trim();
  if (!cedula) return;
  window._searching = true; window._searched = false; window._searchError = '';
  render();
  try {
    const res = await fetch(`/api/my-registrations?cedula=${encodeURIComponent(cedula)}`);
    const data = await res.json();
    if (data.found) { registrations = data.registrations; }
    else { registrations = []; }
    window._searched = true;
  } catch(e) { window._searchError = 'Error de conexión. Intenta de nuevo.'; }
  window._searching = false;
  render();
  // Restore cedula input
  const inp = document.getElementById('cedula-input');
  if (inp) inp.value = cedula;
};

window.handleFileSelect = function(input) {
  const file = input.files?.[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    cropState.image = e.target.result;
    cropState.scale = 1; cropState.offsetX = 0; cropState.offsetY = 0;
    window._uploadError = ''; window._uploadSuccess = false;
    render();
  };
  reader.readAsDataURL(file);
};

window.handleZoomSlider = function(val) {
  cropState.scale = parseFloat(val);
  updateCropImage();
};

window.openCropModal = function(participantId, cedula, photoUrl) {
  cropModal = { open: true, participantId, cedula, currentPhotoUrl: photoUrl };
  cropState = { image: null, scale: 1, offsetX: 0, offsetY: 0 };
  window._uploadError = ''; window._uploadSuccess = false; window._uploading = false;
  render();
};

window.closeCropModal = function() {
  cropModal.open = false;
  cropState.image = null;
  render();
};

window.resetCrop = function() {
  cropState.image = null;
  window._uploadError = '';
  render();
};

window.confirmCrop = async function() {
  if (window._uploading) return;
  const container = document.getElementById('crop-container');
  if (!container) return;

  window._uploading = true;
  document.getElementById('confirm-btn').disabled = true;
  document.getElementById('confirm-btn').textContent = 'Guardando...';

  try {
    // Build cropped canvas
    const size = container.offsetWidth;
    const cropSize = Math.round(size * 0.70);
    const canvas = document.createElement('canvas');
    canvas.width = 400; canvas.height = 400;
    const ctx = canvas.getContext('2d');

    // Clip to circle
    ctx.beginPath();
    ctx.arc(200, 200, 200, 0, Math.PI * 2);
    ctx.clip();

    // Draw the image portion that's inside the circle
    const img = document.getElementById('crop-img');
    const imgRect = img.getBoundingClientRect();
    const contRect = container.getBoundingClientRect();
    const circleCenter = { x: contRect.left + contRect.width / 2, y: contRect.top + contRect.height / 2 };
    const circleR = cropSize / 2;

    // Source coordinates (what part of the original image is inside the circle)
    const scaleX = img.naturalWidth / imgRect.width;
    const scaleY = img.naturalHeight / imgRect.height;
    const sx = (circleCenter.x - circleR - imgRect.left) * scaleX;
    const sy = (circleCenter.y - circleR - imgRect.top) * scaleY;
    const sw = cropSize * scaleX;
    const sh = cropSize * scaleY;

    const tmpImg = new Image();
    tmpImg.src = cropState.image;
    await new Promise(r => tmpImg.onload = r);
    ctx.drawImage(tmpImg, sx, sy, sw, sh, 0, 0, 400, 400);

    const croppedBase64 = canvas.toDataURL('image/jpeg', 0.9);

    const res = await fetch('/api/update-participant-photo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ participantId: cropModal.participantId, cedula: cropModal.cedula, imageBase64: croppedBase64 })
    });
    const data = await res.json();
    if (data.success) {
      window._uploadSuccess = true;
      // Update registration photo locally
      const reg = registrations.find(r => r.id === cropModal.participantId);
      if (reg) reg.photoUrl = data.photoUrl;
      setTimeout(() => { closeCropModal(); }, 1800);
    } else {
      throw new Error(data.error || 'Error desconocido');
    }
  } catch(e) {
    window._uploadError = `Error: ${e.message}`;
  }
  window._uploading = false;
  render();
};

// ---- DRAG OVER UPLOAD ----
document.addEventListener('dragover', e => e.preventDefault());
document.addEventListener('drop', e => {
  e.preventDefault();
  const file = e.dataTransfer?.files?.[0];
  if (!file || !cropModal.open) return;
  const reader = new FileReader();
  reader.onload = ev => {
    cropState.image = ev.target.result;
    cropState.scale = 1; cropState.offsetX = 0; cropState.offsetY = 0;
    render();
  };
  reader.readAsDataURL(file);
});

// Init
window._searching = false; window._searched = false; window._searchError = '';
window._uploading = false; window._uploadError = ''; window._uploadSuccess = false;
render();
</script>
