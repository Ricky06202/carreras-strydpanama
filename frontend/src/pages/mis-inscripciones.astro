---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mis Inscripciones — Carreras by StrydPanama">
  <div class="max-w-3xl mx-auto px-4 py-10">

    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-black dark:text-white text-gray-900 mb-2">
        🔍 Mis Inscripciones
      </h1>
      <p class="dark:text-gray-400 text-gray-500 text-base">
        Busca por tu <strong>cédula / pasaporte</strong> o por tu <strong>código de confirmación</strong> (Ej: STRYD-1A2B3C4D).
      </p>
    </div>

    <!-- Search Card -->
    <div class="dark:bg-slate-800 bg-white rounded-2xl shadow-md p-6 mb-6 border dark:border-slate-700 border-gray-100">
      <div class="flex gap-3">
        <input
          id="cedula-input"
          type="text"
          placeholder="Cédula, pasaporte o código STRYD-XXXXXXXX"
          class="flex-1 dark:bg-slate-700 bg-gray-50 dark:text-white text-gray-900 dark:border-slate-600 border-gray-200 border rounded-xl px-4 py-3 text-base outline-none focus:border-accent transition-colors"
        />
        <button
          id="search-btn"
          onclick="handleSearch()"
          class="bg-accent hover:bg-orange-600 text-white font-bold px-6 py-3 rounded-xl transition-colors whitespace-nowrap"
        >
          Buscar
        </button>
      </div>
      <div id="search-error" class="text-red-500 text-sm mt-3 hidden"></div>
    </div>

    <!-- Results -->
    <div id="results-container"></div>
  </div>

  <!-- Crop Modal -->
  <div id="crop-modal" class="fixed inset-0 bg-black/80 z-50 hidden items-center justify-center p-4">
    <div class="dark:bg-slate-800 bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-2xl">
      <div class="flex items-center justify-between px-6 py-4 border-b dark:border-slate-700 border-gray-100">
        <span class="font-bold text-lg dark:text-white">📸 Actualizar Foto de Perfil</span>
        <button onclick="closeCropModal()" class="text-gray-400 hover:text-gray-600 text-2xl leading-none">&times;</button>
      </div>
      <div class="p-6">
        <p class="text-sm dark:text-gray-400 text-gray-500 text-center mb-4">
          Sube una foto y arrastra para centrar tu cara en el círculo. Usa la rueda del mouse o los dedos para hacer zoom.
        </p>

        <!-- Upload area (shown when no image) -->
        <div id="upload-area"
          onclick="document.getElementById('file-input').click()"
          class="border-2 border-dashed dark:border-slate-600 border-gray-200 rounded-2xl p-10 text-center cursor-pointer hover:border-accent transition-colors"
        >
          <div class="text-5xl mb-3">🤳</div>
          <p class="dark:text-gray-400 text-gray-500 text-sm">Haz clic o arrastra tu foto aquí<br/><span class="text-accent font-semibold">Elige una foto de tu cara</span></p>
          <input type="file" id="file-input" accept="image/*" class="hidden" onchange="handleFileSelect(this)" />
        </div>

        <!-- Crop area (hidden by default) -->
        <div id="crop-area" class="hidden">
          <div
            id="crop-container"
            class="relative w-full bg-black rounded-2xl overflow-hidden cursor-grab active:cursor-grabbing select-none"
            style="aspect-ratio:1"
          >
            <img id="crop-img" class="absolute pointer-events-none" draggable="false" style="transform-origin:center;height:100%;width:auto;" />
            <!-- Overlay with circle cutout -->
            <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(circle 35% at 50% 50%,transparent 99%,rgba(0,0,0,0.65) 100%)"></div>
            <div class="absolute pointer-events-none" style="top:50%;left:50%;transform:translate(-50%,-50%);width:70%;aspect-ratio:1;border-radius:50%;border:3px solid #FF6B00;box-shadow:0 0 0 9999px rgba(0,0,0,0.55)"></div>
            <div class="absolute bottom-3 left-0 right-0 text-center text-white/50 text-xs pointer-events-none">Arrastra para centrar tu cara</div>
          </div>
          <div class="flex items-center gap-3 mt-4">
            <span class="text-sm dark:text-gray-400 text-gray-500 whitespace-nowrap">🔍 Zoom</span>
            <input type="range" id="zoom-slider" min="0.5" max="4" step="0.05" value="1"
              oninput="handleZoom(this.value)"
              class="flex-1 accent-orange-500" />
          </div>
        </div>

        <div id="modal-error" class="text-red-500 text-sm text-center mt-3 hidden"></div>
        <div id="modal-success" class="text-green-500 text-sm text-center mt-3 hidden">✅ ¡Foto actualizada exitosamente!</div>
      </div>

      <div id="modal-footer" class="hidden px-6 pb-6 flex gap-3">
        <button onclick="resetCrop()" class="flex-1 dark:bg-slate-700 bg-gray-100 dark:text-white text-gray-700 font-semibold py-3 rounded-xl hover:opacity-80 transition-opacity">
          ↩ Elegir otra
        </button>
        <button id="confirm-btn" onclick="confirmCrop()" class="flex-[2] bg-accent hover:bg-orange-600 text-white font-bold py-3 rounded-xl transition-colors">
          ✓ Guardar Foto
        </button>
      </div>
    </div>
  </div>
</Layout>

<style>
  .text-accent { color: #FF6B00; }
  .bg-accent { background-color: #FF6B00; }
  .border-accent { border-color: #FF6B00; }
  .hover\:border-accent:hover { border-color: #FF6B00; }
  .focus\:border-accent:focus { border-color: #FF6B00; }
  .hover\:bg-orange-600:hover { background-color: #E55A00; }
  .accent-orange-500 { accent-color: #FF6B00; }
</style>

<script>
  // ── State ──────────────────────────────────────────
  let registrations = [];
  let cropCtx = { participantId: null, cedula: null };
  let cropImg = null;  // base64
  let cropScale = 1, cropX = 0, cropY = 0;

  const SONIC = 'https://api.carreras.strydpanama.com';

  // ── Search ─────────────────────────────────────────
  window.handleSearch = async function() {
    const query = document.getElementById('cedula-input').value.trim();
    if (!query) return;
    const btn = document.getElementById('search-btn');
    const errEl = document.getElementById('search-error');
    const container = document.getElementById('results-container');

    btn.disabled = true;
    btn.textContent = 'Buscando...';
    errEl.classList.add('hidden');
    container.innerHTML = `<div class="text-center py-12 dark:text-gray-400 text-gray-500">⏳ Buscando tus inscripciones...</div>`;

    try {
      const res = await fetch(`/api/my-registrations?cedula=${encodeURIComponent(query)}`);
      const data = await res.json();
      registrations = data.registrations || [];

      // If not found by cedula, try matching by confirmation code (STRYD-XXXXXXXX)
      if (!registrations.length && query.toUpperCase().startsWith('STRYD-')) {
        // already searched, confirmationCode is generated server-side from participant ID
        // Try fetching all and filtering by code client-side isn't possible without cedula
        // so we instruct user
        container.innerHTML = `<div class="text-center py-12 dark:text-gray-400 text-gray-500">
          <div class="text-4xl mb-3">🔍</div>
          <p>No se encontraron resultados con ese código.<br/><span class="text-sm">El código de confirmación debe usarse junto con tu cédula.</span></p>
        </div>`;
        btn.disabled = false; btn.textContent = 'Buscar';
        return;
      }

      renderResults(registrations);
    } catch(e) {
      errEl.textContent = 'Error de conexión. Intenta de nuevo.';
      errEl.classList.remove('hidden');
      container.innerHTML = '';
    }
    btn.disabled = false;
    btn.textContent = 'Buscar';
  };

  // Enter key support
  document.getElementById('cedula-input').addEventListener('keydown', e => {
    if (e.key === 'Enter') window.handleSearch();
  });

  // ── Render Results ──────────────────────────────────
  function ensureAbsolute(url) {
    if (!url) return '';
    if (url.startsWith('http')) return url;
    return `${SONIC}${url.startsWith('/') ? '' : '/'}${url}`;
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    const parts = dateStr.split('T')[0].split('-');
    if (parts.length !== 3) return dateStr;
    const [y, m, d] = parts;
    const months = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];
    return `${parseInt(d)} de ${months[parseInt(m)-1]} de ${y}`;
  }

  function renderResults(regs) {
    const container = document.getElementById('results-container');
    if (!regs.length) {
      container.innerHTML = `
        <div class="text-center py-16 dark:text-gray-500 text-gray-400">
          <div class="text-5xl mb-4">🏃</div>
          <p class="font-semibold dark:text-gray-300 text-gray-600 mb-1">No encontramos inscripciones con esa cédula.</p>
          <p class="text-sm">¿Aún no te has inscrito? <a href="/register" class="text-accent font-semibold hover:underline">Regístrate aquí</a></p>
        </div>`;
      return;
    }

    container.innerHTML = regs.map(reg => {
      const d = reg.race?.date ? formatDate(reg.race.date) : '';
      const imgSrc = ensureAbsolute(reg.race?.imageUrl);
      const photoSrc = ensureAbsolute(reg.photoUrl);
      const studentIdSrc = ensureAbsolute(reg.studentIdUrl);
      const matriculaSrc = ensureAbsolute(reg.matriculaUrl);
      const receiptSrc = ensureAbsolute(reg.receiptUrl);
      const { badgeClass, badgeText } = statusBadge(reg.paymentStatus);

      return `
      <div class="dark:bg-slate-800 bg-white rounded-2xl shadow-md border dark:border-slate-700 border-gray-100 overflow-hidden mb-4">
        <!-- Race header -->
        <div class="flex items-center gap-4 px-5 py-4 border-b dark:border-slate-700 border-gray-100">
          ${imgSrc
            ? `<img src="${imgSrc}" class="w-14 h-14 rounded-xl object-cover flex-shrink-0" />`
            : `<div class="w-14 h-14 rounded-xl dark:bg-slate-700 bg-gray-100 flex items-center justify-center text-2xl flex-shrink-0">🏁</div>`
          }
          <div class="flex-1 min-w-0">
            <div class="font-bold dark:text-white text-gray-900 truncate">${reg.race?.title || 'Carrera'}</div>
            ${d ? `<div class="text-sm dark:text-gray-400 text-gray-500">📅 ${d}</div>` : ''}
          </div>
          <span class="${badgeClass} text-xs font-bold px-3 py-1.5 rounded-full whitespace-nowrap">${badgeText}</span>
        </div>
        <!-- Runner info -->
        <div class="flex items-center gap-4 px-5 py-4">
          <div class="flex-shrink-0">
            ${photoSrc
              ? `<img src="${photoSrc}" class="w-20 h-20 rounded-full object-cover border-[3px] border-accent" />`
              : `<div class="w-20 h-20 rounded-full dark:bg-slate-700 bg-gray-100 border-[3px] dark:border-slate-600 border-gray-200 flex items-center justify-center text-3xl">🏃</div>`
            }
          </div>
          <div class="flex-1 min-w-0">
            <span class="inline-block bg-accent text-white text-xs font-black px-2.5 py-1 rounded-lg mb-1">#${reg.bibNumber || '—'}</span>
            <div class="font-bold dark:text-white text-gray-900">${reg.firstName || ''} ${reg.lastName || ''}</div>
            ${reg.distance ? `<div class="text-sm dark:text-gray-400 text-gray-500">📏 ${reg.distance}</div>` : ''}
            <div class="text-sm mt-1 ${reg.paymentStatus==='confirmed'||reg.paymentStatus==='paid' ? 'text-green-500' : 'text-orange-400'}">
              ${reg.paymentStatus==='confirmed'||reg.paymentStatus==='paid' ? '✅ Inscripción confirmada' : '⏳ En espera de confirmación de pago'}
            </div>
            <div class="text-xs dark:text-gray-500 text-gray-400 mt-1 font-mono">Código: ${reg.confirmationCode || ''}</div>
          </div>
          <button
            onclick="openCropModal('${reg.id}','${reg.cedula||''}')"
            class="flex-shrink-0 border border-accent text-accent text-sm font-semibold px-4 py-2 rounded-xl hover:bg-orange-50 dark:hover:bg-orange-900/20 transition-colors"
          >
            📸 Cambiar Foto
          </button>
        </div>
      </div>`;
    }).join('');
  }

  function statusBadge(status) {
    if (status === 'confirmed' || status === 'paid')
      return { badgeClass: 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 border border-green-300 dark:border-green-700', badgeText: '✅ Confirmado' };
    if (status === 'rejected')
      return { badgeClass: 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 border border-red-300 dark:border-red-700', badgeText: '❌ Rechazado' };
    return { badgeClass: 'bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 border border-orange-300 dark:border-orange-700', badgeText: '⏳ Pendiente' };
  }

  // ── Crop Modal ──────────────────────────────────────
  window.openCropModal = function(participantId, cedula) {
    cropCtx = { participantId, cedula };
    cropImg = null; cropScale = 1; cropX = 0; cropY = 0;
    document.getElementById('upload-area').classList.remove('hidden');
    document.getElementById('crop-area').classList.add('hidden');
    document.getElementById('modal-footer').classList.add('hidden');
    document.getElementById('modal-error').classList.add('hidden');
    document.getElementById('modal-success').classList.add('hidden');
    document.getElementById('confirm-btn').disabled = false;
    document.getElementById('confirm-btn').textContent = '✓ Guardar Foto';
    const modal = document.getElementById('crop-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  };

  window.closeCropModal = function() {
    const modal = document.getElementById('crop-modal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  };

  window.resetCrop = function() {
    cropImg = null;
    document.getElementById('upload-area').classList.remove('hidden');
    document.getElementById('crop-area').classList.add('hidden');
    document.getElementById('modal-footer').classList.add('hidden');
    document.getElementById('modal-error').classList.add('hidden');
  };

  window.handleFileSelect = function(input) {
    const file = input.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      cropImg = e.target.result;
      cropScale = 1; cropX = 0; cropY = 0;
      document.getElementById('upload-area').classList.add('hidden');
      document.getElementById('crop-area').classList.remove('hidden');
      document.getElementById('modal-footer').classList.remove('hidden');
      document.getElementById('zoom-slider').value = 1;
      const img = document.getElementById('crop-img');
      img.src = cropImg;
      updateCropTransform();
    };
    reader.readAsDataURL(file);
    input.value = '';
  };

  window.handleZoom = function(val) {
    cropScale = parseFloat(val);
    updateCropTransform();
  };

  function updateCropTransform() {
    const img = document.getElementById('crop-img');
    if (img) img.style.transform = `scale(${cropScale}) translate(${cropX/cropScale}px,${cropY/cropScale}px)`;
  }

  // Drag events
  let isDragging = false, lastX = 0, lastY = 0;
  document.getElementById('crop-container').addEventListener('mousedown', e => { isDragging=true; lastX=e.clientX; lastY=e.clientY; e.preventDefault(); });
  window.addEventListener('mousemove', e => {
    if (!isDragging) return;
    cropX += e.clientX-lastX; cropY += e.clientY-lastY;
    lastX=e.clientX; lastY=e.clientY;
    updateCropTransform();
  });
  window.addEventListener('mouseup', () => { isDragging=false; });

  // Wheel zoom
  document.getElementById('crop-container').addEventListener('wheel', e => {
    e.preventDefault();
    cropScale = Math.max(0.5, Math.min(4, cropScale - e.deltaY*0.001));
    document.getElementById('zoom-slider').value = cropScale;
    updateCropTransform();
  }, { passive: false });

  // Touch
  let lastTouchDist = 0;
  const cc = document.getElementById('crop-container');
  cc.addEventListener('touchstart', e => {
    if (e.touches.length===1) { lastX=e.touches[0].clientX; lastY=e.touches[0].clientY; }
    if (e.touches.length===2) lastTouchDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
    e.preventDefault();
  }, {passive:false});
  cc.addEventListener('touchmove', e => {
    if (e.touches.length===1) {
      cropX+=e.touches[0].clientX-lastX; cropY+=e.touches[0].clientY-lastY;
      lastX=e.touches[0].clientX; lastY=e.touches[0].clientY;
      updateCropTransform();
    }
    if (e.touches.length===2) {
      const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
      cropScale=Math.max(0.5,Math.min(4,cropScale*(d/lastTouchDist)));
      lastTouchDist=d;
      document.getElementById('zoom-slider').value=cropScale;
      updateCropTransform();
    }
    e.preventDefault();
  }, {passive:false});

  // Drag-and-drop onto upload area
  document.addEventListener('dragover', e=>e.preventDefault());
  document.addEventListener('drop', e => {
    e.preventDefault();
    const file = e.dataTransfer?.files?.[0];
    if (!file || !document.getElementById('crop-modal').classList.contains('flex')) return;
    const reader = new FileReader();
    reader.onload = ev => { window.handleFileSelect({ files:[file] }); };
    reader.readAsDataURL(file);
  });

  // ── Confirm Crop ────────────────────────────────────
  window.confirmCrop = async function() {
    if (!cropImg) return;
    const btn = document.getElementById('confirm-btn');
    const errEl = document.getElementById('modal-error');
    const okEl = document.getElementById('modal-success');
    btn.disabled = true; btn.textContent = 'Guardando...';
    errEl.classList.add('hidden'); okEl.classList.add('hidden');

    try {
      const container = document.getElementById('crop-container');
      const imgEl = document.getElementById('crop-img');
      const containerSize = container.offsetWidth;
      const cropDiameter = Math.round(containerSize * 0.70);

      // Draw the circular crop to canvas
      const canvas = document.createElement('canvas');
      canvas.width=400; canvas.height=400;
      const ctx = canvas.getContext('2d');
      ctx.beginPath(); ctx.arc(200,200,200,0,Math.PI*2); ctx.clip();

      const imgRect = imgEl.getBoundingClientRect();
      const contRect = container.getBoundingClientRect();
      const cx = contRect.left + contRect.width/2;
      const cy = contRect.top + contRect.height/2;
      const r = cropDiameter/2;
      const scaleX = imgEl.naturalWidth / imgRect.width;
      const scaleY = imgEl.naturalHeight / imgRect.height;
      const sx = (cx-r-imgRect.left)*scaleX;
      const sy = (cy-r-imgRect.top)*scaleY;
      const tmpImg = new Image();
      tmpImg.src = cropImg;
      await new Promise(resolve => tmpImg.onload=resolve);
      ctx.drawImage(tmpImg, sx, sy, cropDiameter*scaleX, cropDiameter*scaleY, 0, 0, 400, 400);

      const croppedBase64 = canvas.toDataURL('image/jpeg', 0.9);

      const res = await fetch('/api/update-participant-photo', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ participantId: cropCtx.participantId, cedula: cropCtx.cedula, imageBase64: croppedBase64 })
      });
      const data = await res.json();
      if (data.success) {
        okEl.classList.remove('hidden');
        // Update the photo locally in the rendered card
        const reg = registrations.find(r => r.id === cropCtx.participantId);
        if (reg) reg.photoUrl = data.photoUrl;
        renderResults(registrations);
        setTimeout(() => window.closeCropModal(), 1800);
      } else {
        throw new Error(data.error || 'Error desconocido');
      }
    } catch(e) {
      errEl.textContent = `Error: ${e.message}`;
      errEl.classList.remove('hidden');
    }
    btn.disabled=false; btn.textContent='✓ Guardar Foto';
  };
</script>
