---
import AstroLayout from '../layouts/Layout.astro';
import Layout from '../components/Layout';
import RegistrationForm from '../components/RegistrationForm';
import { api } from '../lib/api';
import { env } from 'cloudflare:workers';

let racesData = { data: [] };

try {
  const response = await api.getPublicRaces(env);
  racesData = response;
} catch (e) {
  console.error('Error fetching races:', e);
}

const raceId = Astro.url.searchParams.get('race') || '';
let sonicjsApiUrl = env.SONICJS_API_URL;
// Fix sonicjsApiUrl if it's missing the "api." subdomain
if (sonicjsApiUrl && typeof sonicjsApiUrl === 'string' && !sonicjsApiUrl.includes('api.')) {
  // Convert URLs like https://carreras.strydpanama.com to https://api.carreras.strydpanama.com
  sonicjsApiUrl = sonicjsApiUrl.replace(
    /^(https?:\/\/)[^.]+\./,
    '$1api.carreras.'
  );
}
---

<AstroLayout title="Registro - Carreras by StrydPanama">
  <Layout client:only="react" maxWidth="sm">
    <RegistrationForm client:only="react" raceId={raceId} initialRaces={racesData.data} sonicjsApiUrl={sonicjsApiUrl} />
  </Layout>
</AstroLayout>
