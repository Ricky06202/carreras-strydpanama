---
import { env } from 'cloudflare:workers';
import { apiFetch } from '../lib/api';

// Obtener todas las carreras activas o recientes
let races: any[] = [];
let selectedRaceId = Astro.url.searchParams.get('raceId') || '';

try {
  const res = await apiFetch('/api/collections/races/content?limit=50', env, { method: 'GET' });
  races = (res?.data || []).map((r: any) => ({
    id: r.id,
    title: r.data?.title || r.title,
    status: r.data?.status,
    date: r.data?.date,
  })).filter((r: any) => ['active', 'finished'].includes(r.status));
  
  if (!selectedRaceId && races.length > 0) {
    const active = races.find((r: any) => r.status === 'active');
    selectedRaceId = active?.id || races[0].id;
  }
} catch(e) {}

// Obtener participantes + distancias + categorías para la carrera seleccionada
let allFinishers: any[] = [];
let distanceMap: Record<string, string> = {};
let categoryMap: Record<string, string> = {};
let distanceNames: string[] = [];
let categoryNames: string[] = [];

if (selectedRaceId) {
  try {
    const [partsRes, distsRes, catsRes] = await Promise.all([
      apiFetch(`/api/collections/participants/content?limit=2000`, env, { method: 'GET' }),
      apiFetch(`/api/collections/distances/content?limit=200`, env, { method: 'GET' }),
      apiFetch(`/api/collections/categories/content?limit=200`, env, { method: 'GET' }),
    ]);

    // Mapear distancias
    const allDists = (distsRes?.data || []).filter((d: any) => d.data?.race === selectedRaceId);
    for (const d of allDists) {
      distanceMap[d.id] = d.data?.title || d.title;
    }
    distanceNames = [...new Set(Object.values(distanceMap))].sort();

    // Mapear categorías
    const allCats = (catsRes?.data || []).filter((c: any) => c.data?.race === selectedRaceId || !c.data?.race);
    for (const c of allCats) {
      categoryMap[c.id] = c.data?.title || c.title;
    }

    // Obtener todos los participantes con finishTime
    const allParts = (partsRes?.data || []).filter((p: any) => 
      (p.data?.race === selectedRaceId || p.data?.raceId === selectedRaceId) && p.data?.finishTime
    );

    // Recolectar categorías que realmente tienen participantes
    const usedCategoryNames = new Set<string>();

    allFinishers = allParts
      .sort((a: any, b: any) => Number(a.data.finishTime) - Number(b.data.finishTime))
      .map((p: any, i: number) => {
        const catId = p.data?.category || p.data?.categoryId || '';
        const catName = p.data?.categoryName || categoryMap[catId] || 'General';
        const distName = distanceMap[p.data?.distance] || 'General';
        if (catName) usedCategoryNames.add(catName);
        return {
          position: i + 1,
          name: `${p.data?.firstName || ''} ${p.data?.lastName || ''}`.trim(),
          bib: p.data?.bibNumber,
          finishTime: Number(p.data?.finishTime),
          photoUrl: p.data?.photoUrl || '',
          country: p.data?.country || '',
          teamName: p.data?.teamName || '',
          categoryName: catName,
          distanceName: distName,
          distanceId: p.data?.distance || '',
          categoryId: catId,
          id: p.id,
        };
      });

    categoryNames = [...usedCategoryNames].sort();
  } catch(e) {}
}

function formatTime(secs: number): string {
  const s = Number(secs);
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

const selectedRace = races.find(r => r.id === selectedRaceId);
const medals = ['🥇', '🥈', '🥉'];
const medalLabels = ['1°', '2°', '3°'];

// Serializar datos para el script del cliente
const clientData = JSON.stringify({
  finishers: allFinishers,
  distanceNames,
  categoryNames,
});
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Resultados y Podio — STRYD Panama</title>
  <meta name="description" content="Resultados y podio en vivo de las carreras STRYD Panama. Filtra por distancia y categoría." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #fff;
      min-height: 100vh;
    }

    /* --- HEADER --- */
    .header {
      background: #000;
      border-bottom: 2px solid #FF6B00;
      padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo { color: #FF6B00; font-size: 20px; font-weight: 900; letter-spacing: 2px; }
    .race-title { font-size: 15px; font-weight: 700; opacity: 0.9; margin-top: 2px; }
    .live-badge {
      background: #FF6B00; color: #fff; padding: 4px 12px;
      border-radius: 20px; font-size: 11px; font-weight: 700;
      letter-spacing: 1px; animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }

    /* --- CONTAINER --- */
    .container { max-width: 1200px; margin: 0 auto; padding: 32px 16px; }

    /* --- RACE SELECTOR --- */
    .race-selector-bar {
      display: flex; gap: 10px; justify-content: center; margin-bottom: 28px; flex-wrap: wrap;
    }
    .race-btn {
      background: #1a1a1a; border: 1px solid #333; color: #fff;
      padding: 8px 20px; border-radius: 20px; cursor: pointer;
      font-size: 13px; text-decoration: none; transition: all 0.2s;
      font-family: inherit;
    }
    .race-btn:hover, .race-btn.active { background: #FF6B00; border-color: #FF6B00; }

    /* --- FILTERS --- */
    .filters-section {
      background: #111; border: 1px solid #1f1f1f; border-radius: 16px;
      padding: 20px; margin-bottom: 32px;
    }
    .filters-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 16px; flex-wrap: wrap; gap: 8px;
    }
    .filters-title {
      font-size: 13px; text-transform: uppercase; letter-spacing: 2px;
      color: #888; font-weight: 700;
    }
    .result-count {
      font-size: 13px; color: #FF6B00; font-weight: 600;
    }
    .filter-row {
      display: flex; flex-direction: column; gap: 12px;
    }
    .filter-group { display: flex; flex-direction: column; gap: 6px; }
    .filter-label {
      font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
      color: #666; font-weight: 600;
    }
    .filter-chips {
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .filter-chip {
      background: #1a1a1a; border: 1px solid #333; color: #aaa;
      padding: 6px 14px; border-radius: 20px; cursor: pointer;
      font-size: 12px; transition: all 0.2s; font-family: inherit; font-weight: 500;
    }
    .filter-chip:hover { border-color: #FF6B00; color: #FF6B00; }
    .filter-chip.active {
      background: #FF6B00; border-color: #FF6B00; color: #fff; font-weight: 700;
    }
    .search-input {
      background: #1a1a1a; border: 1px solid #333; color: #fff;
      padding: 10px 16px; border-radius: 12px; font-size: 14px;
      width: 100%; max-width: 400px; font-family: inherit;
      transition: border-color 0.2s;
    }
    .search-input::placeholder { color: #555; }
    .search-input:focus { outline: none; border-color: #FF6B00; }

    /* --- PODIUM (TOP 3) --- */
    .podium-section { margin-bottom: 40px; }
    .section-title {
      font-size: 14px; text-transform: uppercase; letter-spacing: 3px;
      color: #FF6B00; font-weight: 700; margin-bottom: 24px;
      text-align: center;
    }
    .podium-grid {
      display: grid; grid-template-columns: 1fr 1.3fr 1fr;
      gap: 16px; align-items: end; max-width: 800px; margin: 0 auto 40px;
    }
    @media (max-width: 640px) {
      .podium-grid { grid-template-columns: 1fr; gap: 12px; }
    }
    .podium-card {
      background: #111; border-radius: 20px; text-align: center;
      overflow: hidden; position: relative; transition: transform 0.3s;
    }
    .podium-card:hover { transform: translateY(-4px); }
    .podium-card.first {
      background: linear-gradient(135deg, #1a1500, #111);
      border: 2px solid #FFD700;
      box-shadow: 0 0 40px rgba(255,215,0,0.12);
    }
    .podium-card.second { border: 1px solid #C0C0C0; }
    .podium-card.third { border: 1px solid #CD7F32; }
    .card-platform { padding: 28px 16px 20px; }
    .position-badge { font-size: 44px; margin-bottom: 10px; display: block; }
    .runner-photo {
      width: 88px; height: 88px; border-radius: 50%; object-fit: cover;
      margin: 0 auto 10px; display: block; border: 3px solid #FF6B00;
    }
    .runner-photo-placeholder {
      width: 88px; height: 88px; border-radius: 50%; background: #2a2a2a;
      display: flex; align-items: center; justify-content: center; font-size: 32px;
      border: 3px solid #333; margin: 0 auto 10px;
    }
    .first .runner-photo { border-color: #FFD700; }
    .runner-name { font-size: 16px; font-weight: 900; margin-bottom: 4px; }
    .runner-bib { font-size: 12px; color: #888; margin-bottom: 10px; }
    .finish-time {
      font-size: 20px; font-weight: 900; color: #FF6B00;
      background: rgba(255,107,0,0.1);
      padding: 6px 14px; border-radius: 10px; display: inline-block;
    }
    .first .finish-time { color: #FFD700; background: rgba(255,215,0,0.1); }
    .podium-base {
      padding: 10px; font-size: 11px; font-weight: 700;
      letter-spacing: 2px; text-transform: uppercase; opacity: 0.5;
    }
    .first .podium-base { background: rgba(255,215,0,0.05); }

    /* --- FULL RESULTS TABLE --- */
    .results-table-wrapper {
      background: #111; border: 1px solid #1f1f1f; border-radius: 16px;
      overflow: hidden;
    }
    .results-table {
      width: 100%; border-collapse: collapse;
    }
    .results-table thead th {
      background: #0f0f0f; padding: 14px 16px; text-align: left;
      font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px;
      color: #666; font-weight: 700; border-bottom: 1px solid #1f1f1f;
      position: sticky; top: 0; z-index: 1;
    }
    .results-table tbody tr {
      transition: background 0.15s;
      border-bottom: 1px solid #1a1a1a;
    }
    .results-table tbody tr:hover { background: rgba(255,107,0,0.04); }
    .results-table tbody td {
      padding: 12px 16px; font-size: 14px;
    }
    .pos-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px; border-radius: 50%;
      font-weight: 900; font-size: 13px;
    }
    .pos-gold { background: rgba(255,215,0,0.15); color: #FFD700; }
    .pos-silver { background: rgba(192,192,192,0.15); color: #C0C0C0; }
    .pos-bronze { background: rgba(205,127,50,0.15); color: #CD7F32; }
    .pos-normal { background: #1a1a1a; color: #888; }
    .td-name { font-weight: 700; }
    .td-bib { color: #FF6B00; font-weight: 700; }
    .td-time { font-weight: 900; font-variant-numeric: tabular-nums; }
    .td-category {
      font-size: 12px; color: #888; background: #1a1a1a;
      padding: 3px 10px; border-radius: 12px; display: inline-block;
    }
    .td-team { font-size: 12px; color: #888; }
    .mini-photo {
      width: 32px; height: 32px; border-radius: 50%; object-fit: cover;
      border: 2px solid #333; vertical-align: middle; margin-right: 8px;
    }

    /* --- EMPTY / MISC --- */
    .empty-state { text-align: center; padding: 80px 20px; color: #555; }
    .empty-state div { font-size: 60px; margin-bottom: 16px; }
    .refresh-info { text-align: center; color: #444; font-size: 12px; padding: 20px; }
    .divider { border: none; border-top: 1px solid #1a1a1a; margin: 32px 0; }
    .hidden { display: none; }

    @media (max-width: 768px) {
      .results-table thead th:nth-child(5),
      .results-table tbody td:nth-child(5),
      .results-table thead th:nth-child(7),
      .results-table tbody td:nth-child(7) { display: none; }
    }
    @media (max-width: 480px) {
      .results-table thead th:nth-child(6),
      .results-table tbody td:nth-child(6) { display: none; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div>
      <div class="logo">STRYD PANAMA</div>
      {selectedRace && <div class="race-title">{selectedRace.title}</div>}
    </div>
    <div style="display:flex;align-items:center;gap:16px;">
      <a href="/" style="color:#888;text-decoration:none;font-size:13px;">← Inicio</a>
      <span class="live-badge">● EN VIVO</span>
    </div>
  </header>

  <div class="container">
    {races.length > 1 && (
      <div class="race-selector-bar">
        {races.map(r => (
          <a href={`/podio?raceId=${r.id}`} class={`race-btn ${r.id === selectedRaceId ? 'active' : ''}`}>
            {r.title}
          </a>
        ))}
      </div>
    )}

    {allFinishers.length === 0 ? (
      <div class="empty-state">
        <div>🏁</div>
        <h2 style="color:#666;margin-bottom:8px;">Aún no hay resultados</h2>
        <p>El podio se actualizará automáticamente cuando los corredores lleguen a la meta.</p>
      </div>
    ) : (
      <div id="results-app">
        <!-- Filters -->
        <div class="filters-section">
          <div class="filters-header">
            <span class="filters-title">🔍 Filtrar Resultados</span>
            <span class="result-count" id="result-count"></span>
          </div>
          <div class="filter-row">
            <div style="margin-bottom:8px;">
              <input type="text" class="search-input" id="search-input" placeholder="Buscar por nombre, dorsal o equipo..." />
            </div>
            {distanceNames.length > 0 && (
              <div class="filter-group">
                <span class="filter-label">Distancia</span>
                <div class="filter-chips" id="distance-filters">
                  <button class="filter-chip active" data-distance="all">Todas</button>
                  {distanceNames.map(d => (
                    <button class="filter-chip" data-distance={d}>{d}</button>
                  ))}
                </div>
              </div>
            )}
            {categoryNames.length > 0 && (
              <div class="filter-group">
                <span class="filter-label">Categoría</span>
                <div class="filter-chips" id="category-filters">
                  <button class="filter-chip active" data-category="all">Todas</button>
                  {categoryNames.map(c => (
                    <button class="filter-chip" data-category={c}>{c}</button>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- Podium (Top 3 of current filter) -->
        <div id="podium-container" class="podium-section">
          <div class="section-title" id="podium-title">━━ 🏆 PODIO ━━</div>
          <div class="podium-grid" id="podium-grid">
            <!-- Filled by JS -->
          </div>
        </div>

        <hr class="divider" />

        <!-- Full results table -->
        <div class="results-table-wrapper">
          <table class="results-table">
            <thead>
              <tr>
                <th>Pos</th>
                <th>Corredor</th>
                <th>Dorsal</th>
                <th>Tiempo</th>
                <th>Categoría</th>
                <th>Distancia</th>
                <th>País</th>
              </tr>
            </thead>
            <tbody id="results-body">
              <!-- Filled by JS -->
            </tbody>
          </table>
        </div>
      </div>
    )}

    <div class="refresh-info">
      🔄 Esta página se actualiza automáticamente cada 30 segundos
    </div>
  </div>

  <script define:vars={{ clientData }}>
    const data = JSON.parse(clientData);
    const allFinishers = data.finishers;

    let activeDistance = 'all';
    let activeCategory = 'all';
    let searchQuery = '';

    const medals = ['🥇', '🥈', '🥉'];
    const medalLabels = ['1°', '2°', '3°'];

    function formatTime(secs) {
      const s = Number(secs);
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const sec = Math.floor(s % 60);
      if (h > 0) return h + ':' + String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
      return String(m).padStart(2,'0') + ':' + String(sec).padStart(2,'0');
    }

    function getFiltered() {
      let results = [...allFinishers];
      if (activeDistance !== 'all') {
        results = results.filter(r => r.distanceName === activeDistance);
      }
      if (activeCategory !== 'all') {
        results = results.filter(r => r.categoryName === activeCategory);
      }
      if (searchQuery) {
        const q = searchQuery.toLowerCase();
        results = results.filter(r =>
          r.name.toLowerCase().includes(q) ||
          String(r.bib).includes(q) ||
          (r.teamName || '').toLowerCase().includes(q)
        );
      }
      // Re-rank positions within the filtered set
      results.sort((a, b) => a.finishTime - b.finishTime);
      results.forEach((r, i) => { r.filteredPosition = i + 1; });
      return results;
    }

    function renderPodium(filtered) {
      const podiumGrid = document.getElementById('podium-grid');
      const podiumTitle = document.getElementById('podium-title');
      const podiumContainer = document.getElementById('podium-container');
      if (!podiumGrid) return;

      const top3 = filtered.slice(0, 3);
      if (top3.length === 0) {
        podiumContainer.classList.add('hidden');
        return;
      }
      podiumContainer.classList.remove('hidden');

      let titleText = '━━ 🏆 PODIO';
      if (activeCategory !== 'all') titleText += ' — ' + activeCategory;
      else if (activeDistance !== 'all') titleText += ' — ' + activeDistance;
      titleText += ' ━━';
      podiumTitle.textContent = titleText;

      // Order: 2° - 1° - 3° for visual podium effect
      const order = [1, 0, 2];
      let html = '';
      for (const idx of order) {
        const runner = top3[idx];
        if (!runner) {
          html += '<div></div>';
          continue;
        }
        const posClass = idx === 0 ? 'first' : idx === 1 ? 'second' : 'third';
        const medal = medals[idx] || '';
        const photoHtml = runner.photoUrl
          ? '<img src="' + runner.photoUrl + '" alt="' + runner.name + '" class="runner-photo" loading="lazy" />'
          : '<div class="runner-photo-placeholder">🏃</div>';
        html += '<div class="podium-card ' + posClass + '">' +
          '<div class="card-platform">' +
            '<span class="position-badge">' + medal + '</span>' +
            photoHtml +
            '<div class="runner-name">' + runner.name + '</div>' +
            '<div class="runner-bib">#' + runner.bib + (runner.country ? ' • ' + runner.country : '') + '</div>' +
            '<div class="finish-time">' + formatTime(runner.finishTime) + '</div>' +
          '</div>' +
          '<div class="podium-base">' + medalLabels[idx] + ' Lugar</div>' +
        '</div>';
      }
      podiumGrid.innerHTML = html;
    }

    function renderTable(filtered) {
      const tbody = document.getElementById('results-body');
      const countEl = document.getElementById('result-count');
      if (!tbody) return;

      countEl.textContent = filtered.length + ' resultado' + (filtered.length !== 1 ? 's' : '');

      if (filtered.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:#555;">No se encontraron resultados con los filtros seleccionados</td></tr>';
        return;
      }

      let html = '';
      for (const r of filtered) {
        const pos = r.filteredPosition;
        let posClass = 'pos-normal';
        if (pos === 1) posClass = 'pos-gold';
        else if (pos === 2) posClass = 'pos-silver';
        else if (pos === 3) posClass = 'pos-bronze';

        const photoHtml = r.photoUrl
          ? '<img src="' + r.photoUrl + '" alt="" class="mini-photo" />'
          : '';

        html += '<tr>' +
          '<td><span class="pos-badge ' + posClass + '">' + pos + '</span></td>' +
          '<td class="td-name">' + photoHtml + r.name + '</td>' +
          '<td class="td-bib">#' + r.bib + '</td>' +
          '<td class="td-time">' + formatTime(r.finishTime) + '</td>' +
          '<td><span class="td-category">' + (r.categoryName || '-') + '</span></td>' +
          '<td style="color:#888;font-size:13px;">' + (r.distanceName || '-') + '</td>' +
          '<td style="color:#888;font-size:13px;">' + (r.country || '-') + '</td>' +
        '</tr>';
      }
      tbody.innerHTML = html;
    }

    function render() {
      const filtered = getFiltered();
      renderPodium(filtered);
      renderTable(filtered);
    }

    // Distance filter chips
    document.querySelectorAll('#distance-filters .filter-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#distance-filters .filter-chip').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeDistance = btn.dataset.distance;
        render();
      });
    });

    // Category filter chips
    document.querySelectorAll('#category-filters .filter-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('#category-filters .filter-chip').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.dataset.category;
        render();
      });
    });

    // Search
    const searchInput = document.getElementById('search-input');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = e.target.value;
        render();
      });
    }

    // Initial render
    render();

    // Auto-refresh cada 30 segundos
    setTimeout(() => window.location.reload(), 30000);
  </script>
</body>
</html>
