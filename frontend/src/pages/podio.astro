---
import { env } from 'cloudflare:workers';
import { apiFetch } from '../lib/api';

// Obtener todas las carreras activas o recientes
let races: any[] = [];
let selectedRaceId = Astro.url.searchParams.get('raceId') || '';

try {
  const res = await apiFetch('/api/collections/races/content?limit=50', env, { method: 'GET' });
  races = (res?.data || []).map((r: any) => ({
    id: r.id,
    title: r.data?.title || r.title,
    status: r.data?.status,
    date: r.data?.date,
  })).filter((r: any) => ['active', 'finished'].includes(r.status));
  
  if (!selectedRaceId && races.length > 0) {
    // Preferir carrera activa
    const active = races.find((r: any) => r.status === 'active');
    selectedRaceId = active?.id || races[0].id;
  }
} catch(e) {}

// Obtener participantes + distancias para la carrera seleccionada
let podiumByDistance: Record<string, { distanceName: string; top3: any[] }> = {};

if (selectedRaceId) {
  try {
    const [partsRes, distsRes] = await Promise.all([
      apiFetch(`/api/collections/participants/content?limit=1000`, env, { method: 'GET' }),
      apiFetch(`/api/collections/distances/content?limit=200`, env, { method: 'GET' }),
    ]);

    const allDists = (distsRes?.data || []).filter((d: any) => d.data?.race === selectedRaceId);
    const allParts = (partsRes?.data || []).filter((p: any) => 
      (p.data?.race === selectedRaceId || p.data?.raceId === selectedRaceId) && p.data?.finishTime
    );

    for (const dist of allDists) {
      const distId = dist.id;
      const distName = dist.data?.title || dist.title;
      const partsInDist = allParts
        .filter((p: any) => p.data?.distance === distId)
        .sort((a: any, b: any) => Number(a.data.finishTime) - Number(b.data.finishTime))
        .slice(0, 3)
        .map((p: any, i: number) => ({
          position: i + 1,
          name: `${p.data?.firstName || ''} ${p.data?.lastName || ''}`.trim(),
          bib: p.data?.bibNumber,
          finishTime: p.data?.finishTime,
          photoUrl: p.data?.photoUrl || '',
          country: p.data?.country || '',
          id: p.id,
        }));

      if (partsInDist.length > 0) {
        podiumByDistance[distId] = { distanceName: distName, top3: partsInDist };
      }
    }
  } catch(e) {}
}

function formatTime(secs: number): string {
  const s = Number(secs);
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = s % 60;
  if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

const selectedRace = races.find(r => r.id === selectedRaceId);
const podiumDistances = Object.values(podiumByDistance);
const medals = ['🥇', '🥈', '🥉'];
const medalColors = ['#FFD700', '#C0C0C0', '#CD7F32'];
const medalLabels = ['1°', '2°', '3°'];
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Podio en Vivo — STRYD Panama</title>
  <meta name="description" content="Resultados y podio en vivo de las carreras STRYD Panama" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #fff;
      min-height: 100vh;
    }
    .header {
      background: #000;
      border-bottom: 2px solid #FF6B00;
      padding: 20px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo { color: #FF6B00; font-size: 22px; font-weight: 900; letter-spacing: 2px; }
    .race-title { font-size: 18px; font-weight: 700; opacity: 0.9; }
    .race-select {
      background: #1a1a1a; border: 1px solid #FF6B00; color: #fff;
      padding: 8px 16px; border-radius: 8px; font-size: 14px; cursor: pointer;
    }
    .live-badge {
      background: #FF6B00; color: #fff; padding: 4px 12px;
      border-radius: 20px; font-size: 11px; font-weight: 700;
      letter-spacing: 1px; animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }

    .container { max-width: 1400px; margin: 0 auto; padding: 40px 24px; }
    .distance-section { margin-bottom: 60px; }
    .distance-title {
      font-size: 14px; text-transform: uppercase; letter-spacing: 3px;
      color: #FF6B00; font-weight: 700; margin-bottom: 32px;
      text-align: center;
    }
    .podium-grid {
      display: grid;
      grid-template-columns: 1fr 1.3fr 1fr;
      gap: 20px;
      align-items: end;
      max-width: 900px;
      margin: 0 auto;
    }
    .podium-card {
      background: #111;
      border-radius: 20px;
      text-align: center;
      overflow: hidden;
      position: relative;
      transition: transform 0.3s;
    }
    .podium-card:hover { transform: translateY(-4px); }
    .podium-card.first {
      background: linear-gradient(135deg, #1a1500, #111);
      border: 2px solid #FFD700;
      box-shadow: 0 0 40px rgba(255,215,0,0.15);
    }
    .podium-card.second { border: 1px solid #C0C0C0; }
    .podium-card.third { border: 1px solid #CD7F32; }

    .card-platform {
      padding: 32px 20px 24px;
    }
    .position-badge {
      font-size: 48px; margin-bottom: 12px; display: block;
    }
    .runner-photo {
      width: 100px; height: 100px; border-radius: 50%;
      object-fit: cover; margin-bottom: 12px;
      border: 3px solid #FF6B00;
      display: block; margin-left: auto; margin-right: auto;
    }
    .runner-photo-placeholder {
      width: 100px; height: 100px; border-radius: 50%;
      background: #2a2a2a; display: flex; align-items: center;
      justify-content: center; font-size: 36px;
      border: 3px solid #333;
      margin: 0 auto 12px;
    }
    .first .runner-photo { border-color: #FFD700; }
    .runner-name {
      font-size: 18px; font-weight: 900; margin-bottom: 4px;
    }
    .runner-bib { font-size: 13px; color: #888; margin-bottom: 12px; }
    .finish-time {
      font-size: 22px; font-weight: 900; color: #FF6B00;
      background: rgba(255,107,0,0.1);
      padding: 8px 16px; border-radius: 10px; display: inline-block;
    }
    .first .finish-time { color: #FFD700; background: rgba(255,215,0,0.1); }

    .podium-base {
      padding: 12px;
      font-size: 12px; font-weight: 700; letter-spacing: 2px;
      text-transform: uppercase; opacity: 0.5;
    }
    .first .podium-base { background: rgba(255,215,0,0.05); }

    .empty-state {
      text-align: center; padding: 80px 20px; color: #555;
    }
    .empty-state div { font-size: 60px; margin-bottom: 16px; }

    .refresh-info {
      text-align: center; color: #444; font-size: 12px; padding: 20px;
    }
    .race-selector-bar {
      display: flex; gap: 12px; justify-content: center; margin-bottom: 40px; flex-wrap: wrap;
    }
    .race-btn {
      background: #1a1a1a; border: 1px solid #333; color: #fff;
      padding: 10px 24px; border-radius: 20px; cursor: pointer;
      font-size: 14px; text-decoration: none; transition: all 0.2s;
    }
    .race-btn:hover, .race-btn.active {
      background: #FF6B00; border-color: #FF6B00;
    }
    .divider { border: none; border-top: 1px solid #1a1a1a; margin: 40px 0; }
  </style>
</head>
<body>
  <header class="header">
    <div>
      <div class="logo">STRYD PANAMA</div>
      {selectedRace && <div class="race-title">{selectedRace.title}</div>}
    </div>
    <div style="display:flex;align-items:center;gap:16px;">
      <span class="live-badge">● EN VIVO</span>
    </div>
  </header>

  <div class="container">
    {races.length > 1 && (
      <div class="race-selector-bar">
        {races.map(r => (
          <a href={`/podio?raceId=${r.id}`} class={`race-btn ${r.id === selectedRaceId ? 'active' : ''}`}>
            {r.title}
          </a>
        ))}
      </div>
    )}

    {podiumDistances.length === 0 ? (
      <div class="empty-state">
        <div>🏁</div>
        <h2 style="color:#666;margin-bottom:8px;">Aún no hay resultados</h2>
        <p>El podio se actualizará automáticamente cuando los corredores lleguen a la meta.</p>
      </div>
    ) : (
      podiumDistances.map((dist, di) => (
        <div class="distance-section">
          <div class="distance-title">━━ {dist.distanceName} ━━</div>
          <div class="podium-grid">
            {/* Orden: 2° - 1° - 3° para efecto visual de podio */}
            {[1, 0, 2].map(idx => {
              const runner = dist.top3[idx];
              const posClass = idx === 0 ? 'first' : idx === 1 ? 'second' : 'third';
              if (!runner) return <div />;
              return (
                <div class={`podium-card ${posClass}`}>
                  <div class="card-platform">
                    <span class="position-badge">{medals[runner.position - 1]}</span>
                    {runner.photoUrl
                      ? <img src={runner.photoUrl} alt={runner.name} class="runner-photo" loading="lazy" />
                      : <div class="runner-photo-placeholder">🏃</div>
                    }
                    <div class="runner-name">{runner.name}</div>
                    <div class="runner-bib">#{runner.bib} {runner.country && `• ${runner.country}`}</div>
                    <div class="finish-time">{formatTime(runner.finishTime)}</div>
                  </div>
                  <div class="podium-base">{medalLabels[runner.position - 1]} Lugar</div>
                </div>
              );
            })}
          </div>
          {di < podiumDistances.length - 1 && <hr class="divider" />}
        </div>
      ))
    )}

    <div class="refresh-info">
      🔄 Esta página se actualiza automáticamente cada 30 segundos
    </div>
  </div>

  <script>
    // Auto-refresh cada 30 segundos
    setTimeout(() => window.location.reload(), 30000);
  </script>
</body>
</html>
