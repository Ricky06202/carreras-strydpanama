---
import Layout from '../layouts/Layout.astro';
import { env } from 'cloudflare:workers';
import { apiFetch } from '../lib/api';

let races: any[] = [];
let selectedRaceId = Astro.url.searchParams.get('raceId') || '';

try {
  const res = await apiFetch('/api/collections/races/content?limit=50', env, { method: 'GET' });
  races = (res?.data || []).filter((r: any) => ['active', 'finished'].includes(r.data?.status));
  if (!selectedRaceId && races.length > 0) {
    const finished = races.find((r: any) => r.data?.status === 'finished');
    selectedRaceId = finished?.id || races[0].id;
  }
} catch(e) {}

let allFinishers: any[] = [];
let distanceMap: Record<string, string> = {};
let categoryMap: Record<string, string> = {};
let distanceNames: string[] = [];
let categoryNames: string[] = [];
let teamData: any[] = [];

if (selectedRaceId) {
  try {
    const [partsRes, distsRes, catsRes] = await Promise.all([
      apiFetch(`/api/collections/participants/content?limit=2000`, env, { method: 'GET' }),
      apiFetch(`/api/collections/distances/content?limit=200`, env, { method: 'GET' }),
      apiFetch(`/api/collections/categories/content?limit=200`, env, { method: 'GET' }),
    ]);

    const allDists = (distsRes?.data || []).filter((d: any) => d.data?.race === selectedRaceId);
    for (const d of allDists) distanceMap[d.id] = d.data?.title || d.title;
    distanceNames = [...new Set(Object.values(distanceMap))].sort();

    const allCats = (catsRes?.data || []).filter((c: any) => c.data?.race === selectedRaceId || !c.data?.race);
    for (const c of allCats) categoryMap[c.id] = c.data?.title || c.title;

    const allParts = (partsRes?.data || []).filter((p: any) => 
      (p.data?.race === selectedRaceId || p.data?.raceId === selectedRaceId) && p.data?.finishTime
    );

    const usedCats = new Set<string>();
    allFinishers = allParts
      .sort((a: any, b: any) => Number(a.data.finishTime) - Number(b.data.finishTime))
      .map((p: any, i: number) => {
        const catId = p.data?.category || p.data?.categoryId || '';
        const catName = p.data?.categoryName || categoryMap[catId] || 'General';
        const distName = p.data?.distanceName || distanceMap[p.data?.distance] || 'General';
        const gender = (p.data?.gender || '').toLowerCase();
        usedCats.add(catName);
        return {
          pos: i + 1, id: p.id,
          name: `${p.data?.firstName || ''} ${p.data?.lastName || ''}`.trim(),
          bib: p.data?.bibNumber, finishTime: Number(p.data?.finishTime),
          checkpointTime: p.data?.checkpointTime ? Number(p.data.checkpointTime) : null,
          photoUrl: p.data?.photoUrl || '', country: p.data?.country || '',
          teamName: p.data?.teamName || '', categoryName: catName,
          distanceName: distName, gender: gender === 'm' ? 'masculino' : gender === 'f' ? 'femenino' : gender,
          registrationType: p.data?.registrationType || 'individual',
        };
      });
    categoryNames = [...usedCats].sort();

    // Build team data
    const teamMap: Record<string, any[]> = {};
    for (const f of allFinishers) {
      if (f.teamName && f.registrationType === 'team') {
        if (!teamMap[f.teamName]) teamMap[f.teamName] = [];
        teamMap[f.teamName].push(f);
      }
    }
    teamData = Object.entries(teamMap).map(([name, members]) => {
      const totalTime = members.reduce((s: number, m: any) => s + m.finishTime, 0);
      const complete = members.length === 4; // Solo equipos con los 4 completados
      return { name, members, totalTime, complete, totalMembers: members.length };
    })
    .sort((a, b) => {
      // Equipos completos primero, luego por tiempo total ascendente
      if (a.complete && !b.complete) return -1;
      if (!a.complete && b.complete) return 1;
      return a.totalTime - b.totalTime;
    });
  } catch(e) {}
}

const selectedRace = races.find(r => r.id === selectedRaceId);
const raceName = selectedRace?.data?.title || selectedRace?.title || '';

function formatTime(secs: number): string {
  const s = Number(secs);
  const h = Math.floor(s / 3600);
  const m = Math.floor((s % 3600) / 60);
  const sec = Math.floor(s % 60);
  if (h > 0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}

const clientData = JSON.stringify({ finishers: allFinishers, distanceNames, categoryNames, teamData });
const medals = ['🥇', '🥈', '🥉'];

// Stats para el hero
const totalFinishers = allFinishers.length;
const males = allFinishers.filter(f => f.gender === 'masculino');
const females = allFinishers.filter(f => f.gender === 'femenino');
const fastestM = males[0];
const fastestF = females[0];
const avgTime = totalFinishers > 0 ? Math.round(allFinishers.reduce((s,f) => s + f.finishTime, 0) / totalFinishers) : 0;
const mPct = totalFinishers > 0 ? Math.round(males.length / totalFinishers * 100) : 50;
const hasCheckpoints = allFinishers.some(f => f.checkpointTime);
---

<Layout title={`Resultados — ${raceName || 'STRYD Panama'}`}>
<style>
  :root { --accent: #FF6B00; --accent-dim: rgba(255,107,0,0.1); --card: #161b22; --card2: #1c2128; --border: #21262d; --text: #e6edf3; --muted: #7d8590; }
  .results-page { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); }
  .results-inner { max-width: 1100px; margin: 0 auto; padding: 0 20px; }

  /* Race selector */
  .race-selector { display: flex; gap: 8px; justify-content: center; margin-bottom: 28px; flex-wrap: wrap; }
  .race-chip { background: var(--card); border: 1px solid var(--border); color: var(--muted); padding: 8px 20px; border-radius: 20px; cursor: pointer; font-size: 13px; font-weight: 600; text-decoration: none; transition: all 0.2s; }
  .race-chip:hover, .race-chip.active { background: var(--accent); border-color: var(--accent); color: #fff; }

  /* Stats hero */
  .stats-hero { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; }
  .stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 18px 14px; text-align: center; }
  .stat-value { font-size: 26px; font-weight: 900; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; }
  .stat-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); margin-top: 6px; }

  /* Gender split */
  .gender-split { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 16px 20px; margin-bottom: 28px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .gender-bar-wrap { flex: 1; min-width: 200px; }
  .gender-bar { height: 10px; border-radius: 99px; overflow: hidden; background: #ec4899; display: flex; }
  .gender-bar-m { background: #3b82f6; border-radius: 99px 0 0 99px; transition: width 0.6s; }
  .gender-legend { display: flex; gap: 16px; margin-top: 8px; }
  .gender-dot { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 5px; vertical-align: middle; }

  /* Tabs */
  .tabs { display: flex; gap: 0; border-bottom: 2px solid var(--border); margin-bottom: 24px; }
  .tab { padding: 12px 24px; cursor: pointer; font-weight: 700; font-size: 13px; color: var(--muted); border-bottom: 3px solid transparent; transition: all 0.2s; background: none; border-top: none; border-left: none; border-right: none; text-transform: uppercase; letter-spacing: 1px; }
  .tab:hover { color: var(--accent); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* Podium */
  .podium-section { display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 32px; }
  .podium-block { flex: 1; min-width: 260px; background: var(--card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
  .podium-title { background: var(--card2); padding: 14px 16px; font-weight: 800; font-size: 14px; border-bottom: 1px solid var(--border); color: #fff; }
  .podium-list { padding: 12px; display: flex; flex-direction: column; gap: 8px; }
  .podium-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 10px; border: 1px solid var(--border);
    text-decoration: none; color: var(--text); transition: background 0.15s;
  }
  .podium-item:hover { background: var(--accent-dim); }
  .podium-item.p1 { background: rgba(255,215,0,0.06); border-color: rgba(255,215,0,0.25); }
  .podium-item.p2 { background: rgba(192,192,192,0.05); border-color: rgba(192,192,192,0.2); }
  .podium-item.p3 { background: rgba(205,127,50,0.05); border-color: rgba(205,127,50,0.2); }
  .podium-medal { font-size: 22px; min-width: 28px; text-align: center; }
  .podium-info { flex: 1; min-width: 0; }
  .podium-name { font-weight: 700; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .podium-bib { font-size: 11px; color: var(--accent); font-weight: 600; margin-top: 2px; }
  .podium-time { font-family: ui-monospace, monospace; font-weight: 900; font-size: 16px; color: #fff; white-space: nowrap; }

  /* Filters */
  .filters-bar { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 20px; }
  .filter-row { display: flex; flex-direction: column; gap: 14px; }
  .filter-group { display: flex; flex-direction: column; gap: 6px; }
  .filter-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--muted); font-weight: 700; }
  .chip-row { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip { background: var(--card2); border: 1px solid var(--border); color: var(--muted); padding: 5px 14px; border-radius: 20px; cursor: pointer; font-size: 12px; font-weight: 600; transition: all 0.15s; }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .search-wrap { position: relative; }
  .search-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 15px; pointer-events: none; }
  .search-box { background: var(--card2); border: 1px solid var(--border); color: var(--text); padding: 10px 16px 10px 40px; border-radius: 12px; font-size: 14px; width: 100%; transition: border-color 0.2s; }
  .search-box:focus { outline: none; border-color: var(--accent); }
  .filter-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; flex-wrap: wrap; gap: 8px; }
  .result-count { font-size: 13px; color: var(--accent); font-weight: 700; }

  /* Results Table */
  .results-wrap { background: var(--card); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
  .results-table { width: 100%; border-collapse: collapse; }
  .results-table thead th { background: var(--card2); padding: 13px 14px; text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--accent); font-weight: 800; border-bottom: 1px solid var(--border); position: sticky; top: 0; }
  .results-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.12s; cursor: pointer; }
  .results-table tbody tr:hover { background: var(--accent-dim); }
  .results-table tbody tr.tr-top1 { background: rgba(255,215,0,0.05); }
  .results-table tbody tr.tr-top2 { background: rgba(180,180,180,0.04); }
  .results-table tbody tr.tr-top3 { background: rgba(180,100,40,0.05); }
  .results-table tbody td { padding: 11px 14px; font-size: 13px; }
  .pos-badge { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 50%; font-weight: 900; font-size: 12px; }
  .pos-1 { background: rgba(255,215,0,0.15); color: #FFD700; }
  .pos-2 { background: rgba(192,192,192,0.15); color: #C0C0C0; }
  .pos-3 { background: rgba(205,127,50,0.15); color: #CD7F32; }
  .pos-n { background: var(--card2); color: var(--muted); }
  .td-bib { color: var(--accent); font-weight: 700; font-variant-numeric: tabular-nums; }
  .td-time { font-weight: 900; font-variant-numeric: tabular-nums; font-family: ui-monospace, monospace; }
  .td-cat { font-size: 11px; color: var(--muted); background: var(--card2); padding: 3px 9px; border-radius: 10px; display: inline-block; border: 1px solid var(--border); }
  .mini-photo { width: 34px; height: 34px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent); vertical-align: middle; margin-right: 8px; flex-shrink: 0; }
  .mini-photo-placeholder { width: 34px; height: 34px; border-radius: 50%; background: #2a2a2a; border: 2px solid #333; vertical-align: middle; margin-right: 8px; display: inline-flex; align-items: center; justify-content: center; font-size: 15px; flex-shrink: 0; }

  /* Mobile card list (hidden on desktop) */
  .card-list { display: none; }
  .result-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; cursor: pointer; transition: border-color 0.15s, transform 0.15s; margin-bottom: 8px; text-decoration: none; color: var(--text); }
  .result-card:hover { border-color: var(--accent); transform: translateX(2px); }
  .result-card.rc-top1 { border-left: 3px solid #FFD700; }
  .result-card.rc-top2 { border-left: 3px solid #C0C0C0; }
  .result-card.rc-top3 { border-left: 3px solid #CD7F32; }
  .rc-pos { font-size: 11px; font-weight: 900; color: var(--muted); min-width: 24px; text-align: center; }
  .rc-info { flex: 1; min-width: 0; }
  .rc-name { font-weight: 700; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rc-meta { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .rc-time { font-weight: 900; font-size: 15px; color: var(--accent); font-family: ui-monospace, monospace; white-space: nowrap; }
  .rc-bib { font-size: 11px; color: var(--accent); font-weight: 700; }

  /* Teams */
  .teams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; }
  .team-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 20px 22px; transition: border-color 0.2s, transform 0.15s; }
  .team-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .team-card.gold { border-left: 4px solid #c9a227; }
  .team-card.silver { border-left: 4px solid #8a9ba8; }
  .team-card.bronze { border-left: 4px solid #8b5e3c; }
  .team-rank { font-size: 22px; margin-bottom: 4px; }
  .team-name { font-weight: 900; font-size: 16px; color: var(--text); margin-bottom: 2px; }
  .team-total-label { font-size: 12px; color: var(--muted); margin-bottom: 14px; }
  .team-total-time { font-weight: 900; color: var(--accent); font-family: ui-monospace, monospace; }
  .team-divider { border: none; border-top: 1px solid var(--border); margin: 12px 0; }
  .team-members-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; font-weight: 700; }
  .team-members { display: flex; flex-direction: column; gap: 5px; }
  .team-member { display: flex; align-items: center; gap: 0; text-decoration: none; color: var(--text); padding: 4px 0; border-bottom: 1px dashed var(--border); }
  .team-member:last-child { border-bottom: none; }
  .team-member:hover .member-name { color: var(--accent); }
  .member-bib { font-size: 12px; color: var(--accent); font-weight: 800; font-family: ui-monospace, monospace; min-width: 38px; }
  .member-name { flex: 1; font-size: 13px; font-weight: 600; }
  .member-sep { color: var(--muted); margin: 0 6px; font-size: 11px; }
  .member-time { font-weight: 800; font-size: 13px; font-family: ui-monospace, monospace; color: var(--muted); }

  .empty-state { text-align: center; padding: 80px 20px; color: var(--muted); }
  .empty-icon { font-size: 60px; margin-bottom: 16px; }
  .section-divider { border: none; border-top: 1px solid var(--border); margin: 28px 0; }
  .hidden { display: none; }

  @media (max-width: 768px) {
    .stats-hero { grid-template-columns: repeat(2, 1fr); }
    .podium-row { flex-direction: column; gap: 16px; }
    .podium-block { min-width: 100%; }
    .podium-item { padding: 12px 14px; gap: 10px; }
    .podium-medal { font-size: 22px; min-width: 28px; }
    .podium-photo, .podium-photo-placeholder { width: 44px; height: 44px; font-size: 18px; }
    .podium-name { font-size: 14px; }
    .podium-time { font-size: 15px; }
    /* Table hidden on mobile, cards shown */
    .results-wrap { display: none; }
    .card-list { display: block; }
    .filters-bar { padding: 14px; }
    .tab { padding: 10px 16px; font-size: 11px; }
    .teams-grid { grid-template-columns: 1fr; }
    .team-card { padding: 16px; }
  }
  @media (min-width: 769px) {
    .card-list { display: none !important; }
  }
</style>

<div class="results-page">
<div class="results-inner">
  <!-- Race Selector -->
  {races.length > 0 && (
    <div class="race-selector">
      {races.map(r => (
        <a href={`/resultados?raceId=${r.id}`} class={`race-chip ${r.id === selectedRaceId ? 'active' : ''}`}>
          {r.data?.title || r.title}
        </a>
      ))}
    </div>
  )}

  {allFinishers.length > 0 && (
    <div style="text-align:center;margin-bottom:24px;">
      <a href={`/premiacion?raceId=${selectedRaceId}`} style="display:inline-flex;align-items:center;gap:8px;background:#1a1a1a;border:1px solid #FF6B00;color:#FF6B00;padding:10px 22px;border-radius:12px;font-weight:700;font-size:14px;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background='#FF6B00';this.style.color='#fff'" onmouseout="this.style.background='#1a1a1a';this.style.color='#FF6B00'">
        🏆 Ver Informe de Premiación
      </a>
    </div>
  )}

  {allFinishers.length > 0 && (
    <>
      <!-- Stats Hero -->
      <div class="stats-hero">
        <div class="stat-card">
          <div class="stat-value">{totalFinishers}</div>
          <div class="stat-label">Finishers</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{fastestM ? formatTime(fastestM.finishTime) : '—'}</div>
          <div class="stat-label">Mejor Masculino</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{fastestF ? formatTime(fastestF.finishTime) : '—'}</div>
          <div class="stat-label">Mejor Femenino</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{avgTime ? formatTime(avgTime) : '—'}</div>
          <div class="stat-label">Tiempo Promedio</div>
        </div>
      </div>

      <!-- Gender Split -->
      <div class="gender-split">
        <div style="font-size:11px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);font-weight:700;white-space:nowrap;">Distribución</div>
        <div class="gender-bar-wrap">
          <div class="gender-bar">
            <div class="gender-bar-m" style={`width:${mPct}%`}></div>
          </div>
          <div class="gender-legend">
            <span style="font-size:12px;color:#7d8590;"><span class="gender-dot" style="background:#3b82f6;"></span>Masculino {mPct}%</span>
            <span style="font-size:12px;color:#7d8590;"><span class="gender-dot" style="background:#ec4899;"></span>Femenino {100-mPct}%</span>
          </div>
        </div>
        <div style="font-size:13px;color:var(--muted);white-space:nowrap;">{males.length}M · {females.length}F</div>
      </div>
    </>
  )}

  {allFinishers.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">🏁</div>
      <h2 style="color:#666;margin-bottom:8px;">Aún no hay resultados</h2>
      <p>Los resultados aparecerán cuando los corredores lleguen a la meta.</p>
    </div>
  ) : (
    <div id="results-app">
      <!-- Tabs -->
      <div class="tabs">
        <button class="tab active" data-tab="individual">🏃 Individual</button>
        <button class="tab" data-tab="equipos">👥 Equipos</button>
      </div>

      <!-- TAB: Individual -->
      <div class="tab-content active" id="tab-individual">
        <!-- Podium: Top 3 M + Top 3 F -->
        <div class="podium-section" id="podium-section">
          <div class="podium-block">
            <div class="podium-title">🏆 Podio Masculino</div>
            <div class="podium-list" id="podium-male"></div>
          </div>
          <div class="podium-block">
            <div class="podium-title">🏆 Podio Femenino</div>
            <div class="podium-list" id="podium-female"></div>
          </div>
        </div>

        <hr class="section-divider" />

        <!-- Filters -->
        <div class="filters-bar">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
            <span style="font-size:13px;text-transform:uppercase;letter-spacing:2px;color:#888;font-weight:700;">🔍 Filtrar Resultados</span>
            <span class="result-count" id="result-count"></span>
          </div>
          <div class="filter-row">
            <div class="search-wrap">
              <span class="search-icon">🔍</span>
              <input type="text" class="search-box" id="search-input" placeholder="Buscar por nombre, dorsal o equipo..." />
            </div>
            {distanceNames.length > 0 && (
              <div class="filter-group">
                <span class="filter-label">Distancia</span>
                <div class="chip-row" id="dist-chips">
                  <button class="chip active" data-val="all">Todas</button>
                  {distanceNames.map(d => <button class="chip" data-val={d}>{d}</button>)}
                </div>
              </div>
            )}
            {categoryNames.length > 0 && (
              <div class="filter-group">
                <span class="filter-label">Categoría</span>
                <div class="chip-row" id="cat-chips">
                  <button class="chip active" data-val="all">Todas</button>
                  {categoryNames.map(c => <button class="chip" data-val={c}>{c}</button>)}
                </div>
              </div>
            )}
            <div class="filter-group">
              <span class="filter-label">Género</span>
              <div class="chip-row" id="gender-chips">
                <button class="chip active" data-val="all">Todos</button>
                <button class="chip" data-val="masculino">Masculino</button>
                <button class="chip" data-val="femenino">Femenino</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Results Table (desktop) -->
        <div class="results-wrap">
          <table class="results-table">
            <thead><tr>
              <th>Pos</th><th>Corredor</th><th>Dorsal</th><th>Tiempo</th>{hasCheckpoints && <th>Retorno</th>}<th>Categoría</th><th>Distancia</th><th>Equipo</th>
            </tr></thead>
            <tbody id="results-body"></tbody>
          </table>
        </div>

        <!-- Results Cards (mobile) -->
        <div class="card-list" id="card-list"></div>
      </div>

      <!-- TAB: Equipos -->
      <div class="tab-content" id="tab-equipos">
        <div id="teams-container"></div>
      </div>
    </div>
  )}
</div><!-- results-inner -->
</div><!-- results-page -->

<script define:vars={{ clientData, hasCheckpoints }}>
  const data = JSON.parse(clientData);
  const all = data.finishers;
  const teams = data.teamData;
  const medals = ['🥇', '🥈', '🥉'];

  let fDist = 'all', fCat = 'all', fGender = 'all', fSearch = '';

  function fmt(secs) {
    const s = Number(secs); const h = Math.floor(s/3600);
    const m = Math.floor((s%3600)/60); const sec = Math.floor(s%60);
    if (h > 0) return h+':'+String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
    return String(m).padStart(2,'0')+':'+String(sec).padStart(2,'0');
  }

  function getFiltered() {
    let r = [...all];
    if (fDist !== 'all') r = r.filter(x => x.distanceName === fDist);
    if (fCat !== 'all') r = r.filter(x => x.categoryName === fCat);
    if (fGender !== 'all') r = r.filter(x => x.gender === fGender);
    if (fSearch) {
      const q = fSearch.toLowerCase();
      r = r.filter(x => x.name.toLowerCase().includes(q) || String(x.bib).includes(q) || (x.teamName||'').toLowerCase().includes(q));
    }
    r.sort((a,b) => a.finishTime - b.finishTime);
    r.forEach((x,i) => { x.fPos = i+1; });
    return r;
  }

  function renderPodium() {
    const maleList = document.getElementById('podium-male');
    const femaleList = document.getElementById('podium-female');
    if (!maleList || !femaleList) return;

    const males = all.filter(x => x.gender === 'masculino').slice(0, 3);
    const females = all.filter(x => x.gender === 'femenino').slice(0, 3);

    [{ el: maleList, data: males }, { el: femaleList, data: females }].forEach(({ el, data: list }) => {
      if (list.length === 0) { el.innerHTML = '<div style="text-align:center;color:#555;padding:20px;">Sin resultados</div>'; return; }
      el.innerHTML = list.map((r, i) => {
        return `<a href="/corredor/${r.id}" class="podium-item p${i+1}">
          <span class="podium-medal">${medals[i]}</span>
          <div class="podium-info">
            <div class="podium-name">${r.name}</div>
            <div class="podium-bib">#${r.bib}</div>
          </div>
          <div class="podium-time">${fmt(r.finishTime)}</div>
        </a>`;
      }).join('');
    });
  }

  function renderTable(filtered) {
    const tbody = document.getElementById('results-body');
    const countEl = document.getElementById('result-count');
    if (!tbody) return;
    countEl.textContent = filtered.length + ' resultado' + (filtered.length !== 1 ? 's' : '');

    if (filtered.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:#555;">Sin resultados para los filtros seleccionados</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map(r => {
      const pc = r.fPos <= 3 ? `pos-${r.fPos}` : 'pos-n';
      const trCls = r.fPos === 1 ? 'tr-top1' : r.fPos === 2 ? 'tr-top2' : r.fPos === 3 ? 'tr-top3' : '';
      const cpCell = hasCheckpoints
        ? `<td class="td-time" style="color:#aaa;font-size:12px;">${r.checkpointTime ? fmt(r.checkpointTime) : '—'}</td>`
        : '';
      return `<tr class="${trCls}" onclick="window.location='/corredor/${r.id}'">
        <td><span class="pos-badge ${pc}">${r.fPos}</span></td>
        <td style="font-weight:700;">${r.name}</td>
        <td class="td-bib">#${r.bib}</td>
        <td class="td-time">${fmt(r.finishTime)}</td>
        ${cpCell}
        <td><span class="td-cat">${r.categoryName}</span></td>
        <td style="color:#888;font-size:12px;">${r.distanceName}</td>
        <td style="color:#888;font-size:12px;">${r.teamName || '—'}</td>
      </tr>`;
    }).join('');
  }

  function renderCards(filtered) {
    const list = document.getElementById('card-list');
    if (!list) return;
    if (filtered.length === 0) { list.innerHTML = ''; return; }
    list.innerHTML = filtered.map(r => {
      const rcCls = r.fPos === 1 ? 'rc-top1' : r.fPos === 2 ? 'rc-top2' : r.fPos === 3 ? 'rc-top3' : '';
      return `<a href="/corredor/${r.id}" class="result-card ${rcCls}">
        <div class="rc-pos">${r.fPos <= 3 ? medals[r.fPos-1] : r.fPos}</div>
        <div class="rc-info">
          <div class="rc-name">${r.name}</div>
          <div class="rc-meta">${r.categoryName} · ${r.distanceName}${r.teamName ? ' · ' + r.teamName : ''}</div>
          <div class="rc-bib">#${r.bib}${r.checkpointTime ? ` · 🔁 ${fmt(r.checkpointTime)}` : ''}</div>
        </div>
        <div class="rc-time">${fmt(r.finishTime)}</div>
      </a>`;
    }).join('');
  }

  function renderTeams() {
    const container = document.getElementById('teams-container');
    if (!container) return;
    if (teams.length === 0) {
      container.innerHTML = '<div style="text-align:center;color:#555;padding:60px;">No hay equipos registrados con tiempos.</div>';
      return;
    }
    // Separar completos e incompletos
    const completeTeams = teams.filter(t => t.complete);
    const incompleteTeams = teams.filter(t => !t.complete);
    const ranked = [...completeTeams, ...incompleteTeams];

    container.innerHTML = `<div class="teams-grid">${ranked.map((t) => {
      const isComplete = t.complete;
      const rank = isComplete ? completeTeams.indexOf(t) : -1;
      const cls = rank === 0 ? 'gold' : rank === 1 ? 'silver' : rank === 2 ? 'bronze' : '';
      const medal = isComplete && rank < 3 ? medals[rank] : isComplete ? `#${rank+1}` : '⏳';
      return `<div class="team-card ${cls}" style="${!isComplete ? 'opacity:0.55;' : ''}">
        <div class="team-rank">${medal}</div>
        <div class="team-name">${t.name}</div>
        <div class="team-total-label">
          ${isComplete
            ? `Tiempo total (suma): <span class="team-total-time">${fmt(t.totalTime)}</span>`
            : `En progreso: ${t.totalMembers}/4 en meta`}
        </div>
        <hr class="team-divider"/>
        <div class="team-members-label">Integrantes</div>
        <div class="team-members">
          ${t.members.sort((a,b) => a.finishTime - b.finishTime).map(m => `
            <a href="/corredor/${m.id}" class="team-member">
              <span class="member-bib">#${m.bib}</span>
              <span class="member-name">${m.name}</span>
              <span class="member-sep">—</span>
              <span class="member-time">${fmt(m.finishTime)}</span>
            </a>
          `).join('')}
        </div>
      </div>`;
    }).join('')}</div>`;
  }

  function render() {
    const filtered = getFiltered();
    renderTable(filtered);
    renderCards(filtered);
  }

  // Tab switching
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById('tab-' + tab.dataset.tab)?.classList.add('active');
    });
  });

  // Filter chips
  function setupChips(containerId, setter) {
    document.querySelectorAll(`#${containerId} .chip`).forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll(`#${containerId} .chip`).forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        setter(btn.dataset.val);
        render();
      });
    });
  }
  setupChips('dist-chips', v => fDist = v);
  setupChips('cat-chips', v => fCat = v);
  setupChips('gender-chips', v => fGender = v);

  const si = document.getElementById('search-input');
  if (si) si.addEventListener('input', e => { fSearch = e.target.value; render(); });

  // Initial render
  renderPodium();
  render();
  renderTeams();
</script>
</Layout>
