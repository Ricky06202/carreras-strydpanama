---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Carreras Panama' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script type="module" src="https://bt-cdn.yappy.cloud/v1/cdn/web-component-btn-yappy.js" is:inline></script>
    <script is:inline>
      // Set theme IMMEDIATELY to prevent flash - MUST be first thing in head
      (function() {
        var theme = localStorage.getItem('theme');
        if (!theme) {
          theme = 'dark';
          localStorage.setItem('theme', theme);
        }
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-white dark:bg-slate-900 shadow-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-3 md:py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 min-w-0">
          <div class="w-9 h-9 md:w-10 md:h-10 bg-accent rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 md:w-6 md:h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="text-base md:text-xl font-bold text-accent truncate">Carreras by StrydPanama</span>
        </a>
        
        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-6">
          <a href="/" class="hover:text-accent transition-colors font-medium dark:text-white">Carreras</a>
          <a href="/register" class="hover:text-accent transition-colors font-medium dark:text-white">Inscribirse</a>
          <a href="/resultados" class="hover:text-accent transition-colors font-medium dark:text-white">🏆 Resultados</a>
          <a href="/mis-inscripciones" class="hover:text-accent transition-colors font-medium dark:text-white">Mis Inscripciones</a>
          <button id="theme-toggle" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors text-gray-500 dark:text-gray-400" aria-label="Toggle Dark Mode">
            <svg id="theme-toggle-dark-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
            <svg id="theme-toggle-light-icon" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
          </button>
        </nav>

        <!-- Mobile: theme toggle + hamburger -->
        <div class="flex items-center gap-2 md:hidden">
          <button id="theme-toggle-mobile" class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors text-gray-500 dark:text-gray-400" aria-label="Toggle Dark Mode">
            <svg id="theme-toggle-dark-icon-mobile" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
            <svg id="theme-toggle-light-icon-mobile" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
          </button>
          <button id="mobile-menu-btn" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors text-gray-600 dark:text-gray-300" aria-label="Abrir menú">
            <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile nav dropdown -->
      <nav id="mobile-menu" class="md:hidden hidden border-t border-gray-100 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0;">
        <div class="px-4 py-3 flex flex-col gap-1">
          <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors font-medium dark:text-white text-gray-800">
            <span class="text-lg">🏠</span> Carreras
          </a>
          <a href="/register" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors font-medium dark:text-white text-gray-800">
            <span class="text-lg">✍️</span> Inscribirse
          </a>
          <a href="/resultados" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors font-medium dark:text-white text-gray-800">
            <span class="text-lg">🏆</span> Resultados
          </a>
          <a href="/mis-inscripciones" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors font-medium dark:text-white text-gray-800">
            <span class="text-lg">🔍</span> Mis Inscripciones
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-gray-800 dark:bg-slate-900 text-white py-8 md:py-12 mt-auto border-t border-gray-700 dark:border-slate-800">
      <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-6 md:mb-8">
        <div>
          <h5 class="font-bold mb-3 md:mb-4 text-accent text-lg">ENLACES</h5>
          <div class="flex flex-col gap-2">
            <a href="/#proximos-eventos" class="text-gray-300 hover:text-accent transition-colors flex items-center gap-2">📅 Calendario</a>
            <a href="/resultados" class="text-gray-300 hover:text-accent transition-colors flex items-center gap-2">🏆 Resultados</a>
            <a href="/mis-inscripciones" class="text-gray-300 hover:text-accent transition-colors flex items-center gap-2">🔍 Mis Inscripciones</a>
            <a href="https://strydpanama.com" target="_blank" class="text-gray-300 hover:text-accent transition-colors flex items-center gap-2">ℹ️ ¿Quiénes somos?</a>
            <a href="/terminos-y-condiciones" class="text-gray-300 hover:text-accent transition-colors flex items-center gap-2">📄 Términos y condiciones</a>
          </div>
        </div>
        <div>
          <h5 class="font-bold mb-3 md:mb-4 text-accent text-lg">CONTÁCTENOS</h5>
          <div class="flex flex-col gap-2 text-gray-300">
            <p>📍 David, Chiriquí</p>
            <p>📞 WhatsApp: (507) 6676-9050</p>
            <p>✉️ Email: carreras@strydpanama.com</p>
          </div>
        </div>
        <div>
          <h5 class="font-bold mb-3 md:mb-4 text-accent text-lg">STRYD PANAMA</h5>
          <p class="text-gray-300 text-sm leading-relaxed">Una organización deportiva cuya visión es organizar actividades de correr y caminar dentro de una estructura comunitaria que involucre todos los estratos sociales.</p>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-4 text-center border-t border-gray-700 dark:border-slate-800 pt-6 md:pt-8">
        <p class="text-gray-400 text-sm md:text-base">&copy; 2026 Stryd Panama. Todos los derechos reservados.</p>
      </div>
    </footer>

    <script>
      // --- Desktop theme toggle ---
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
      const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');

      // --- Mobile theme toggle ---
      const themeToggleMobileBtn = document.getElementById('theme-toggle-mobile');
      const themeToggleDarkIconMobile = document.getElementById('theme-toggle-dark-icon-mobile');
      const themeToggleLightIconMobile = document.getElementById('theme-toggle-light-icon-mobile');

      function syncThemeIcons() {
        const isDark = localStorage.getItem('theme') === 'dark';
        // Desktop
        if (themeToggleDarkIcon && themeToggleLightIcon) {
          themeToggleDarkIcon.classList.toggle('hidden', isDark);
          themeToggleLightIcon.classList.toggle('hidden', !isDark);
        }
        // Mobile
        if (themeToggleDarkIconMobile && themeToggleLightIconMobile) {
          themeToggleDarkIconMobile.classList.toggle('hidden', isDark);
          themeToggleLightIconMobile.classList.toggle('hidden', !isDark);
        }
      }
      syncThemeIcons();

      function doToggleTheme() {
        let mode = 'light';
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
          mode = 'light';
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
          mode = 'dark';
        }
        document.documentElement.style.colorScheme = mode;
        syncThemeIcons();
        window.dispatchEvent(new CustomEvent('themechange', { detail: { mode } }));
      }

      if (themeToggleBtn) themeToggleBtn.addEventListener('click', doToggleTheme);
      if (themeToggleMobileBtn) themeToggleMobileBtn.addEventListener('click', doToggleTheme);

      // --- Mobile hamburger menu ---
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const hamburgerIcon = document.getElementById('hamburger-icon');
      const closeIcon = document.getElementById('close-icon');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          const isOpen = !mobileMenu.classList.contains('hidden') && mobileMenu.style.maxHeight !== '0px';
          if (isOpen) {
            // Close
            mobileMenu.style.maxHeight = '0px';
            hamburgerIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
            setTimeout(() => mobileMenu.classList.add('hidden'), 300);
          } else {
            // Open
            mobileMenu.classList.remove('hidden');
            requestAnimationFrame(() => {
              mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
            });
            hamburgerIcon?.classList.add('hidden');
            closeIcon?.classList.remove('hidden');
          }
        });

        // Close menu when a link is clicked
        mobileMenu.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.style.maxHeight = '0px';
            hamburgerIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
            setTimeout(() => mobileMenu.classList.add('hidden'), 300);
          });
        });
      }
    </script>
  </body>
</html>