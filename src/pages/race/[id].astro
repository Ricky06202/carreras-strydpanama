---
import Layout from '../../layouts/Layout.astro';
import { getDb } from '../../lib/db';
import { getRaceById, getParticipantsByRace } from '../../lib/db/actions';
import RaceTimer from '../../components/RaceTimer.svelte';
import RaceMap from '../../components/RaceMap.svelte';
import { env } from 'cloudflare:workers';

const db = getDb(env.DB as any);

const raceId = Astro.params.id;
const race = raceId ? await getRaceById(db, raceId) : null;

if (!race) {
  return Astro.redirect('/');
}

const participants = await getParticipantsByRace(db, race.id);

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString('es-PA', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${race.name} - Stryd Panama`}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <a href="/" class="inline-flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-accent mb-6 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a Carreras
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg overflow-hidden">
          {race.imageUrl ? (
            <img src={race.imageUrl} alt={race.name} class="w-full h-64 object-cover" />
          ) : (
            <div class="h-48 bg-gradient-to-br from-accent to-orange-400 flex items-center justify-center relative">
              <svg class="w-24 h-24 text-white opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          )}
          {race.status === 'active' && (
            <div class="absolute top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-full font-bold animate-pulse">
              EN VIVO
            </div>
          )}
          <div class="p-8">
            <h1 class="text-3xl font-bold mb-4 dark:text-white">{race.name}</h1>
            <p class="text-gray-600 dark:text-gray-400 mb-6">{race.description}</p>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="text-2xl font-bold text-accent">{participants.length}</div>
                <div class="text-sm text-gray-500">Participantes</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="text-2xl font-bold text-accent">${race.price}</div>
                <div class="text-sm text-gray-500">Precio</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="text-2xl font-bold text-accent">{race.maxParticipants || '∞'}</div>
                <div class="text-sm text-gray-500">Cupo</div>
              </div>
              <div class="text-center p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
                <div class="text-2xl font-bold text-accent">{formatDate(race.date)}</div>
                <div class="text-sm text-gray-500">Fecha</div>
              </div>
            </div>

            {race.location && (
              <div class="flex items-center gap-2 text-gray-600 dark:text-gray-400 mb-4">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                {race.location}
              </div>
            )}

            {race.technicalInfo && (
              <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6 mb-6">
                <h3 class="text-lg font-bold mb-3 dark:text-white">Información Técnica</h3>
                <p class="text-gray-600 dark:text-gray-400 whitespace-pre-wrap">{race.technicalInfo}</p>
              </div>
            )}

            {race.termsAndConditions && (
              <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-6 mb-6">
                <h3 class="text-lg font-bold mb-3 dark:text-white">Términos y Condiciones</h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm whitespace-pre-wrap">{race.termsAndConditions}</p>
              </div>
            )}

            {race.showTimer && race.status === 'active' && race.timerStart && (
              <div class="bg-orange-50 dark:bg-orange-900/20 border border-orange-200 dark:border-orange-800 rounded-lg p-6 mb-8">
                <h3 class="text-lg font-bold text-orange-800 dark:text-orange-200 mb-4 text-center">Tiempo Transcurrido</h3>
                <RaceTimer client:load startTimestamp={race.timerStart} />
              </div>
            )}

            {(race.status === 'upcoming' || race.status === 'accepting') && (
              <a href={`/register?race=${race.id}`} class="block w-full text-center px-8 py-4 bg-accent text-white text-lg font-bold rounded-lg hover:bg-orange-600 transition-colors">
                Inscribirse Ahora
              </a>
            )}
          </div>
        </div>

        {race.routeGpxUrl && (
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8">
            <h2 class="text-xl font-bold mb-4">Ruta de la Carrera</h2>
            <RaceMap client:load gpxUrl={race.routeGpxUrl} raceName={race.name} />
          </div>
        )}
      </div>

      <div class="space-y-8">
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-6">
          <h2 class="text-xl font-bold mb-4">Participantes Recientes</h2>
          {participants.length === 0 ? (
            <p class="text-gray-500 text-center py-4">Aún no hay participantes</p>
          ) : (
            <div class="space-y-3 max-h-96 overflow-y-auto">
              {participants.slice(0, 10).map((p) => (
                <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
                  <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold">
                    {p.firstName[0]}{p.lastName[0]}
                  </div>
                  <div>
                    <div class="font-medium">{p.firstName} {p.lastName}</div>
                    <div class="text-sm text-gray-500">{p.paymentStatus === 'paid' ? '✓ Pagado' : '⏳ Pendiente'}</div>
                  </div>
                </div>
              ))}
            </div>
          )}
          {participants.length > 10 && (
            <p class="text-center text-gray-500 mt-4 text-sm">+{participants.length - 10} participantes más</p>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>