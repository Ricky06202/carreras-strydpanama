---
import Layout from '../layouts/Layout.astro';
import RegistrationForm from '../components/RegistrationForm';

const raceId = Astro.url.searchParams.get('race') || '';
---

<Layout title="Inscripción - Stryd Panama">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2 dark:text-white">Inscripción</h1>
      <p class="text-gray-600 dark:text-gray-400">Complete sus datos para registrarse en la carrera</p>
    </div>
    
    <RegistrationForm client:load raceId={raceId} />
  </div>
</Layout>