---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Carreras Panama' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://unpkg.com />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script is:inline>
      // Ejecutar inmediatamente antes de renderizar nada
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = savedTheme || (prefersDark ? 'dark' : 'light');
      document.documentElement.classList.add(theme);
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors min-h-screen flex flex-col">
    <header class="bg-white dark:bg-gray-800 shadow-md sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <div class="w-10 h-10 bg-accent rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="text-xl font-bold text-accent">Stryd Panama</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-6">
          <a href="/" class="hover:text-accent transition-colors font-medium dark:text-white">Carreras</a>
          <a href="/register" class="hover:text-accent transition-colors font-medium dark:text-white">Inscribirse</a>
        </nav>

        <button id="theme-toggle" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" aria-label="Toggle theme">
          <span class="sun-icon">🌙</span>
          <span class="moon-icon" style="display:none">☀️</span>
        </button>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-gray-800 dark:bg-gray-950 text-white py-8 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <p class="text-gray-400">&copy; 2026 Stryd Panama. Todos los derechos reservados.</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = toggle?.querySelector('.sun-icon');
      const moonIcon = toggle?.querySelector('.moon-icon');

      function updateIcons() {
        const isDark = document.documentElement.classList.contains('dark');
        if (sunIcon && moonIcon) {
          sunIcon.style.display = isDark ? 'inline' : 'none';
          moonIcon.style.display = isDark ? 'none' : 'inline';
        }
      }

      // Inicializar iconos al cargar
      updateIcons();

      // Toggle click
      toggle?.addEventListener('click', () => {
        const html = document.documentElement;
        const isDark = html.classList.contains('dark');
        const newMode = isDark ? 'light' : 'dark';
        
        if (isDark) {
          html.classList.remove('dark');
          html.classList.add('light');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.remove('light');
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        
        // Dispatch custom event for MUI components
        window.dispatchEvent(new CustomEvent('themechange', { detail: { mode: newMode } }));
        
        updateIcons();
      });

      // Escuchar cambios de tema desde otros componentes
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') {
          const theme = e.newValue;
          const html = document.documentElement;
          html.classList.remove('dark', 'light');
          html.classList.add(theme);
          updateIcons();
        }
      });
    </script>
  </body>
</html>